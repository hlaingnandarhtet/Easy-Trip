@using System.Net.Http.Json
@inject HttpClient Http

<MudDialog Class="et-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 800;">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Class="mr-2" Color="Color.Primary" />
            Transaction Details
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex align-center justify-center pa-6 gap-3">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                <MudText>Loading details...</MudText>
            </div>
        }
        else if (_booking == null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Transaction not found.</MudAlert>
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <span class="et-badge et-badge--indigo">@GetTransactionId(_booking)</span>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">TRANSACTION DATE</MudText>
                    <MudText Style="font-weight: 600; color: #0F172A;">@GetTransactionDate(_booking)</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">TRAVEL DATE</MudText>
                    <MudText Style="font-weight: 600; color: #0F172A;">@_booking.TravelDate.ToString("dd-MM-yyyy")</MudText>
                </MudItem>

                <MudItem xs="12"><MudDivider Class="my-1" /></MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">CUSTOMER</MudText>
                    <MudText Style="font-weight: 700; color: #0F172A;">@(_booking.UserName ?? "—")</MudText>
                    @if (!string.IsNullOrWhiteSpace(_booking.UserEmail))
                    {
                        <MudText Typo="Typo.body2" Style="color: #64748B;">@_booking.UserEmail</MudText>
                    }
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">BOOKING TYPE</MudText>
                    <span class="et-badge et-badge--indigo">@_booking.BookingType</span>
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">SERVICE</MudText>
                    <div class="d-flex align-center gap-2 mt-1">
                        <MudIcon Icon="@GetServiceIcon(_booking)" Size="Size.Small" Style="color: #64748B;" />
                        <MudText Style="font-weight: 500; color: #334155;">@GetServiceDescription(_booking)</MudText>
                    </div>
                </MudItem>

                @if (_booking.Details?.EndDate != null)
                {
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">CHECK-OUT DATE</MudText>
                        <MudText Style="font-weight: 600; color: #0F172A;">@_booking.Details.EndDate?.ToString("dd-MM-yyyy")</MudText>
                    </MudItem>
                }
                @if (!string.IsNullOrWhiteSpace(_booking.Details?.SelectedSeats))
                {
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">SEATS</MudText>
                        <MudText Style="font-weight: 600; color: #0F172A;">@_booking.Details.SelectedSeats</MudText>
                    </MudItem>
                }
                @if (_booking.Details != null && _booking.Details.Quantity > 0 && !_booking.BookingType.Equals("Bus", StringComparison.OrdinalIgnoreCase))
                {
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">QUANTITY</MudText>
                        <MudText Style="font-weight: 600; color: #0F172A;">@_booking.Details.Quantity</MudText>
                    </MudItem>
                }

                <MudItem xs="12"><MudDivider Class="my-1" /></MudItem>

                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">AMOUNT</MudText>
                    <MudText Style="font-weight: 800; color: #0F172A; font-size: 1.1rem;">@_booking.TotalAmount.ToString("N0") mmk</MudText>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">PAYMENT</MudText>
                    <div class="mt-1">
                        @if (_booking.PaymentStatus == PaymentStatus.Paid)
                        {
                            <span class="et-badge et-badge--success">Paid</span>
                        }
                        else if (_booking.PaymentStatus == PaymentStatus.UnderReview)
                        {
                            <span class="et-badge et-badge--warning">Under Review</span>
                        }
                        else
                        {
                            <span class="et-badge et-badge--muted">Unpaid</span>
                        }
                    </div>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 600;">BOOKING STATUS</MudText>
                    <div class="mt-1">
                        @if (_booking.BookingStatusCode == BookingStatusCodes.Pending)
                        {
                            <span class="et-badge et-badge--warning">Pending</span>
                        }
                        else if (_booking.BookingStatusCode == BookingStatusCodes.Confirmed)
                        {
                            <span class="et-badge et-badge--success">Confirmed</span>
                        }
                        else if (_booking.BookingStatusCode == BookingStatusCodes.Rejected)
                        {
                            <span class="et-badge et-badge--danger">Rejected</span>
                        }
                        else
                        {
                            <span class="et-badge et-badge--muted">Unknown</span>
                        }
                    </div>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close" Class="et-btn-primary">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public long BookingId { get; set; }

    private BookingResponseModel? _booking;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _booking = await Http.GetFromJsonAsync<BookingResponseModel>($"api/booking/{BookingId}");
        }
        catch
        {
            _booking = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private void Close() => MudDialog.Close();

    private static string GetTransactionId(BookingResponseModel booking) => $"TXN-{booking.Id:D5}";

    private static string GetTransactionDate(BookingResponseModel booking)
    {
        var date = booking.CreatedAt ?? booking.BookingDate;
        return date.HasValue ? date.Value.ToLocalTime().ToString("dd-MM-yyyy HH:mm") : "—";
    }

    private static string GetServiceDescription(BookingResponseModel b)
    {
        if (b.Details == null) return b.ItemName ?? "—";

        return b.BookingType switch
        {
            "Bus" => $"{b.Details.BusName ?? b.Details.BusNumber ?? "—"}" +
                     (string.IsNullOrEmpty(b.Details.SelectedSeats) ? "" : $" (Seats: {b.Details.SelectedSeats})"),
            "Hotel" => $"{b.Details.HotelName ?? "—"} — {b.Details.HotelRoomTypeName ?? "Room"} × {b.Details.Quantity}",
            _ => $"{b.Details.PackageName ?? b.ItemName ?? "—"}"
        };
    }

    private static string GetServiceIcon(BookingResponseModel b)
    {
        if (b.BookingType.Equals("Bus", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Filled.DirectionsBus;
        if (b.BookingType.Equals("Hotel", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Filled.Hotel;
        return Icons.Material.Filled.CardTravel;
    }

}
