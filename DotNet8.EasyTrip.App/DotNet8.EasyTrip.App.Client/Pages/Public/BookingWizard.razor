                                            </MudText>
                                        }
                                    </div>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </div>
            }

            <!-- Immersive Lightroom Lightbox Modal -->
            @if (isLightboxOpen)
            {
                <div class="lightbox-modal">
                    <div class="lightbox-content-card">
                        <!-- Modal Header -->
                        <div class="lightbox-header">
                            <div class="lightbox-title-tabs">
                                <button class="lightbox-header-tab @(lightboxTab == "Property" ? "active" : "")" type="button" @onclick='() => lightboxTab = "Property"'>Property Images</button>
                                <button class="lightbox-header-tab @(lightboxTab == "Guest" ? "active" : "")" type="button" @onclick='() => lightboxTab = "Guest"'>Guest Images</button>
                            </div>
                            <button class="btn-close-lightbox" type="button" @onclick="CloseLightbox">
                                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Medium" />
                            </button>
                        </div>

                        @if (lightboxTab == "Property")
                        {
                            <!-- Category Filter Pills Bar -->
                            <div class="lightbox-category-bar">
                                <button class="lightbox-category-pill @(lightboxCategory == "All" ? "active" : "")" type="button" @onclick='() => lightboxCategory = "All"'>All (12)</button>
                                <button class="lightbox-category-pill @(lightboxCategory == "Rooms" ? "active" : "")" type="button" @onclick='() => lightboxCategory = "Rooms"'>Rooms (8)</button>
                                <button class="lightbox-category-pill @(lightboxCategory == "Facilities" ? "active" : "")" type="button" @onclick='() => lightboxCategory = "Facilities"'>Facilities (6)</button>
                                <button class="lightbox-category-pill @(lightboxCategory == "Property" ? "active" : "")" type="button" @onclick='() => lightboxCategory = "Property"'>Property views (6)</button>
                            </div>
                        }

                        <!-- Modal Split Content -->
                        <div class="lightbox-body-grid">
                            <!-- Left: Image grid of photos -->
                            <div class="lightbox-photo-scroll">
                                <div class="lightbox-photo-grid">
                                    @{
                                        List<string> activeImages = new();
                                        if (lightboxTab == "Guest")
                                        {
                                            activeImages = guestImages;
                                        }
                                        else
                                        {
                                            if (lightboxCategory == "Rooms") activeImages = hotelRoomImages;
                                            else if (lightboxCategory == "Facilities") activeImages = hotelFacilityImages;
                                            else if (lightboxCategory == "Property") activeImages = hotelBuildingImages;
                                            else
                                            {
                                                activeImages = hotelBuildingImages.Concat(hotelRoomImages).Concat(hotelFacilityImages).Take(12).ToList();
                                            }
                                        }
                                        
                                        @foreach (var imgUrl in activeImages)
                                        {
                                            <div class="lightbox-photo-item">
                                                <img src="@imgUrl" alt="Lightbox Image" style="width:100%; height:100%; object-fit:cover;" />
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Right Sidebar: Ratings breakdowns & testimonial quotes -->
                            <div class="lightbox-modal-sidebar">
                                <div>
                                    <div class="sidebar-rating-card">
                                        <div class="review-score-bubble">8.9</div>
                                        <div>
                                            <span style="font-weight: 800; font-size: 1rem; color: #0f172a; display:block;">8.9 Excellent</span>
                                            <span style="font-size: 0.75rem; color: #64748b;">Based on 53,745 reviews</span>
                                        </div>
                                    </div>

                                    <div class="sidebar-progress-title">Guest review metrics</div>
                                    
                                    <div class="sidebar-progress-row">
                                        <div class="progress-label-row">
                                            <span>Cleanliness</span>
                                            <span style="font-weight:700;">9.2</span>
                                        </div>
                                        <div class="progress-bar-track">
                                            <div class="progress-bar-fill" style="width: 92%;"></div>
                                        </div>
                                    </div>
                                    <div class="sidebar-progress-row">
                                        <div class="progress-label-row">
                                            <span>Facilities</span>
                                            <span style="font-weight:700;">8.8</span>
                                        </div>
                                        <div class="progress-bar-track">
                                            <div class="progress-bar-fill" style="width: 88%;"></div>
                                        </div>
                                    </div>
                                    <div class="sidebar-progress-row">
                                        <div class="progress-label-row">
                                            <span>Location</span>
                                            <span style="font-weight:700;">9.6</span>
                                        </div>
                                        <div class="progress-bar-track">
                                            <div class="progress-bar-fill" style="width: 96%;"></div>
                                        </div>
                                    </div>
                                    <div class="sidebar-progress-row">
                                        <div class="progress-label-row">
                                            <span>Service</span>
                                            <span style="font-weight:700;">9.0</span>
                                        </div>
                                        <div class="progress-bar-track">
                                            <div class="progress-bar-fill" style="width: 90%;"></div>
                                        </div>
                                    </div>
                                    <div class="sidebar-progress-row">
                                        <div class="progress-label-row">
                                            <span>Value for money</span>
                                            <span style="font-weight:700;">9.2</span>
                                        </div>
                                        <div class="progress-bar-track">
                                            <div class="progress-bar-fill" style="width: 92%;"></div>
                                        </div>
                                    </div>

                                    <div class="sidebar-testimonial-title">What guests say</div>
                                    <div class="sidebar-testimonial-carousel mt-2">
                                        <div class="sidebar-testimonial-text">
                                            @guestTestimonials[ItemId.HasValue ? (int)(ItemId.Value % guestTestimonials.Count) : 0]
