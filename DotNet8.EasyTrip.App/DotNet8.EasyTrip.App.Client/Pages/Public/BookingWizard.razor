    private async Task ConfirmBooking()
    {
        IsSubmitting = true;
        
        var request = new PublicBookingRequestModel
        {
            Name = GuestName,
            Phone = GuestPhone,
            Email = GuestEmail,
            BookingType = Type,
            TravelDate = DateOnly.FromDateTime(TravelDateValue!.Value),
            TotalAmount = TotalAmount,
            Quantity = Type == "Bus" ? SelectedSeats.Count : Quantity,
            PaymentType = paymentType,
            TransactionNo = transactionNo,
            ScreenshotImage = screenshotImage
        };

        if (Type == "Bus")
        {
            request.BusId = ItemId;
            request.SelectedSeats = string.Join(",", SelectedSeats);
        }
        else if (Type == "Hotel")
        {
            request.HotelRoomId = SelectedRoomId;
        }
        else if (Type == "Package")
        {
            request.PackageId = ItemId;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/public/bookings", request);
            
            if (response.IsSuccessStatusCode)
            {
                IsBookingConfirmed = true;
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Booking failed: {errorMsg}", Severity.Error);
                if (Type == "Bus")
                    await LoadReservedSeatsAsync();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Network error while submitting booking.", Severity.Error);
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void SelectPaymentMethod(PaymentMethodResponseModel pm)
    {
        selectedPaymentMethod = pm;
        paymentType = pm.PaymentType;
        Snackbar.Add($"Selected {pm.PaymentType.ToUpper()} payment method.", Severity.Success);
    }

    private async Task CopyAccountNumber()
    {
        if (selectedPaymentMethod != null)
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", selectedPaymentMethod.AccountNumber);
            Snackbar.Add("Account number copied to clipboard!", Severity.Info);
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            isUploadingImage = true;
            StateHasChanged();
            try
            {
                if (file.Size > 2 * 1024 * 1024)
                {
                    Snackbar.Add("File size must be less than 2MB.", Severity.Error);
                    return;
                }

                if (!file.ContentType.StartsWith("image/"))
                {
                    Snackbar.Add("Only image files are allowed.", Severity.Error);
                    return;
                }

                screenshotFileName = file.Name;
                
                var buffer = new byte[file.Size];
                using (var stream = file.OpenReadStream(2 * 1024 * 1024))
                {
                    await stream.ReadAsync(buffer);
                }
                
                screenshotImage = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
                Snackbar.Add("Payment slip imported successfully.", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to import file: {ex.Message}", Severity.Error);
            }
            finally
            {
                isUploadingImage = false;
                StateHasChanged();
            }
        }
    }
