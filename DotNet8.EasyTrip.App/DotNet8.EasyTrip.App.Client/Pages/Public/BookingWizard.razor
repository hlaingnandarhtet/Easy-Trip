                            <div class="seat-map-panel">
                                <DotNet8.EasyTrip.App.Client.Pages.Public.SeatMap
                                    @key="@($"{ItemId}-{TravelDateValue:yyyyMMdd}-{ReservedSeatsKey}")"
                                    BusLayoutMetadata="@SelectedBusLayout"
                                    TotalRows="10"
                                    PricePerSeat="@PricePerSeat"
                                    ReservedSeats="@ReservedSeats"
                                    OnSeatsChanged="HandleSeatsSelected" />
                            </div>
                        }
                        else if (Type == "Package" && packageData != null)
                        {
                            <div class="booking-service-card">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@packageData.PackageName</MudText>
                                <div class="service-price">
                                    <strong>@PricePerSeat.ToString("N0") mmk</strong>
                                    <span>per person</span>
                                </div>
                            </div>
                            
                            <div class="package-quantity-field">
                                <MudNumericField @bind-Value="Quantity" Label="Headcount" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </div>
                        }
                    </MudPaper>

                    <!-- Section 2: Guest Info -->
                    <MudPaper Class="checkout-card" Elevation="0">
                        <div class="checkout-section-head">
                            <div class="checkout-step-icon">2</div>
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="checkout-section-title">Guest details</MudText>
                                <MudText Typo="Typo.caption" Class="checkout-section-note">Use the same details you want on the booking voucher.</MudText>
                            </div>
                        </div>
                        
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="GuestName" Label="Full Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="GuestPhone" Label="Phone" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="GuestEmail" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                            </MudItem>
                            @* <MudItem xs="12" sm="6">
                                <MudDatePicker Date="TravelDateValue" DateChanged="OnTravelDateChanged" Label="Travel Date" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                            </MudItem> *@
                        </MudGrid>
                    </MudPaper>

                    <!-- Section 3: Payment Details -->
                    <MudPaper Class="checkout-card mt-4" Elevation="0">
                        <div class="checkout-section-head">
                            <div class="checkout-step-icon">3</div>
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="checkout-section-title">Payment details</MudText>
                                <MudText Typo="Typo.caption" Class="checkout-section-note">Transfer the exact amount and attach the slip screenshot.</MudText>
                            </div>
                        </div>

                        <div class="payment-instruction">
                            Transfer exactly <strong>@TotalAmount.ToString("N0") mmk</strong> to the selected account.
                        </div>

                        <!-- Payment Type Selector Cards -->
                        <div class="payment-method-grid">
                            @foreach (var pm in paymentMethods)
                            {
                                var isSelected = paymentType == pm.PaymentType;
                                <div class="payment-method-card @(isSelected ? "selected" : "")" @onclick="() => SelectPaymentMethod(pm)">
                                    <div class="payment-method-header">
                                        <MudIcon Icon="@(pm.PaymentType switch {
                                            "kpay" => Icons.Material.Filled.AccountBalance,
                                            "wave" => Icons.Material.Filled.SendToMobile,
                                            "aya" => Icons.Material.Filled.AccountBalance,
                                            _ => Icons.Material.Filled.CreditCard
                                        })" Color="@(isSelected ? Color.Primary : Color.Default)" Class="mr-2" />
                                        <span class="payment-method-name">@(pm.PaymentType.ToUpper())</span>
                                    </div>
                                    @if (isSelected)
                                    {
                                        <span class="check-mark">✓</span>
                                    }
                                </div>
                            }
                        </div>

                        @if (selectedPaymentMethod != null)
                        {
                            <div class="admin-account-info-box">
                                <div>
                                    <span class="account-label">Account name</span>
                                    <strong>@selectedPaymentMethod.AccountName</strong>
                                </div>
                                <div class="account-number-row">
                                    <span class="account-label">Account number / phone</span>
                                    <strong>@selectedPaymentMethod.AccountNumber</strong>
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" OnClick="CopyAccountNumber" />
                                </div>
                            </div>

                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="transactionNo" Label="Last Transaction Slip No / Ref No" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Placeholder="Enter reference code or last 6 digits" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <div class="d-flex flex-column">
                                        <label style="font-size: 0.75rem; color: #64748b; margin-bottom: 4px;">Transfer Slip Screenshot *</label>
                                        <div class="d-flex align-center gap-2">
                                            <MudButton HtmlTag="label"
                                                       Variant="Variant.Outlined"
                                                       Color="Color.Primary"
                                                       StartIcon="@Icons.Material.Filled.CloudUpload"
                                                       Style="text-transform: none; border-radius: 8px;">
                                                Upload Screenshot
                                                <InputFile id="fileInput" OnChange="OnInputFileChange" hidden accept="image/*" />
                                            </MudButton>
                                            @if (isUploadingImage)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                            }
                                            else if (!string.IsNullOrEmpty(screenshotFileName))
                                            {
                                                <div class="d-flex align-center gap-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                    <span style="font-size: 0.8rem; color: #0f172a; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@screenshotFileName</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </MudItem>
                            </MudGrid>
                            @if (!string.IsNullOrEmpty(screenshotImage))
                            {
                                <div class="slip-preview">
                                    <img src="@screenshotImage" />
                                </div>
                            }
                        }
                    </MudPaper>
                </MudItem>

                <!-- Right Column: Summary & Checkout -->
                <MudItem xs="12" md="5" lg="4" Class="checkout-summary-column">
                    <MudPaper Class="checkout-summary-card position-sticky" Elevation="0" Style="top: 88px;">
                        <div class="summary-card-head">
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Order summary</MudText>
                            <span>@Type</span>
                        </div>

                        @if (Type == "Bus" && busData != null)
                        {
                            <div class="summary-row">
                                <span>Bus ticket</span>
                                <strong>@busData.BusName</strong>
                            </div>
                            <div class="summary-row">
                                <span>Seats (@SelectedSeats.Count)</span>
                                <strong>@(SelectedSeats.Any() ? string.Join(", ", SelectedSeats) : "-")</strong>
                            </div>
                        }
                        else if (Type == "Package" && packageData != null)
                        {
                            <div class="summary-row">
                                <span>Package</span>
                                <strong>@packageData.PackageName</strong>
                            </div>
                            <div class="summary-row">
                                <span>Guests</span>
                                <strong>@Quantity</strong>
                            </div>
                        }

                        <div class="summary-row summary-row-bordered">
                            <span>Date</span>
                            <strong>@(TravelDateValue?.ToString("dd-MM-yyyy") ?? "-")</strong>
                        </div>

                        <div class="summary-total-row">
                            <span>Total</span>
                            <strong>@TotalAmount.ToString("N0") mmk</strong>
                        </div>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                                   DisableElevation="true"
                                   OnClick="ConfirmBooking" 
                                   Disabled="@(!CanConfirm)">
                            @if (IsSubmitting)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <span class="ms-2">Processing...</span>
                            }
                            else
                            {
                                <span>Confirm Booking</span>
                            }
                        </MudButton>
                        
                        @if (!CanConfirm && !IsSubmitting)
                        {
                            <MudText Typo="Typo.caption" Class="summary-helper">
                                Complete selection and details to proceed.
                            </MudText>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            </div>
        }
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "type")]
    public string Type { get; set; } = "Bus";

    [SupplyParameterFromQuery(Name = "id")]
    public long? ItemId { get; set; }

    private bool isLoading = true;
    private bool IsSubmitting = false;
    private bool IsBookingConfirmed = false;
    private string? ErrorMessage;

    private List<PaymentMethodResponseModel> paymentMethods = new();
    private PaymentMethodResponseModel? selectedPaymentMethod;
    private string? paymentType;
    private string? transactionNo;
    private string? screenshotImage;
    private string? screenshotFileName;
    private bool isUploadingImage = false;

    private BusResponseModel? busData;
    private HotelResponseModel? hotelResponseData;
    private HotelRoomResponseModel? hotelData;
    private List<HotelRoomResponseModel> hotelRooms = new();
    private long? SelectedRoomId;
    private TravelPackageResponseModel? packageData;

    private string SelectedBusLayout = "Standard_2_2"; 
    private List<string> SelectedSeats = new();
    private List<string> ReservedSeats = new();
    private int ReservedSeatsKey;
    private decimal PricePerSeat = 0m;
    private int Quantity = 1;

    private decimal TotalAmount => Type == "Bus" 
        ? SelectedSeats.Count * PricePerSeat 
        : Quantity * PricePerSeat;

    private void OnRoomSelected(long? roomId)
    {
        SelectedRoomId = roomId;
        hotelData = roomId.HasValue
            ? hotelRooms.FirstOrDefault(r => r.Id == roomId.Value)
            : null;
        PricePerSeat = hotelData?.PricePerNight ?? 0m;
        Quantity = 1;
    }

    private string GuestName = "";
    private string GuestPhone = "";
    private string GuestEmail = "";
    private DateTime? TravelDateValue = DateTime.Today.AddDays(1);

    private bool IsSelectionValid => Type == "Bus" ? SelectedSeats.Count > 0 : (Type == "Hotel" ? SelectedRoomId != null : Quantity > 0);
    
    private bool IsGuestInfoValid()
    {
        return !string.IsNullOrWhiteSpace(GuestName) && 
               !string.IsNullOrWhiteSpace(GuestPhone) && 
               !string.IsNullOrWhiteSpace(GuestEmail) && 
               GuestEmail.Contains("@") &&
               TravelDateValue.HasValue;
    }

    private bool IsPaymentInfoValid()
    {
        return !string.IsNullOrWhiteSpace(paymentType) &&
               !string.IsNullOrWhiteSpace(transactionNo) &&
               !string.IsNullOrWhiteSpace(screenshotImage);
    }

    private bool CanConfirm => IsGuestInfoValid() && IsSelectionValid && IsPaymentInfoValid() && !IsSubmitting && !isUploadingImage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            try
            {
                var methods = await Http.GetFromJsonAsync<List<PaymentMethodResponseModel>>("api/payment/methods");
                paymentMethods = methods ?? new();
            }
            catch (Exception)
            {
                Snackbar.Add("Failed to load payment methods.", Severity.Error);
            }

            if (ItemId.HasValue)
            {
                if (Type == "Bus")
                {
                    busData = await Http.GetFromJsonAsync<BusResponseModel>($"api/bus/{ItemId}");
                    if (busData != null)
                    {
                        if (!string.IsNullOrEmpty(busData.BusClass) && busData.BusClass.Contains("2+1"))
                            SelectedBusLayout = "VIP_2_1";
                        else
                            SelectedBusLayout = "Standard_2_2";
                        
                        PricePerSeat = busData.Price ?? 0m;
                        await LoadReservedSeatsAsync();
                    }
                    else
                    {
                        ErrorMessage = "Bus not found.";
                    }
                }
                else if (Type == "Hotel")
                {
                    hotelResponseData = await Http.GetFromJsonAsync<HotelResponseModel>($"api/hotel/{ItemId}");
                    if (hotelResponseData != null)
                    {
                        var rooms = await Http.GetFromJsonAsync<List<HotelRoomResponseModel>>($"api/hotel/{ItemId}/room");
                        hotelRooms = rooms ?? new();
                    }
                    else
                    {
                        ErrorMessage = "Hotel not found.";
                    }
                }
                else if (Type == "Package")
                {
                    packageData = await Http.GetFromJsonAsync<TravelPackageResponseModel>($"api/travelpackage/{ItemId}");
                    if (packageData != null)
                    {
                        PricePerSeat = packageData.PackagePrice;
                        if (packageData.StartDate != default)
                        {
                            TravelDateValue = packageData.StartDate;
                        }
                    }
                    else
                    {
                        ErrorMessage = "Travel package not found.";
                    }
                }
            }
            else
            {
                ErrorMessage = "Invalid booking reference (Missing ID).";
            }
        }
        catch (Exception)
        {
            ErrorMessage = "Failed to load booking details from the server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleSeatsSelected(List<string> seats)
    {
        SelectedSeats = seats;
    }

    private async Task OnTravelDateChanged(DateTime? date)
    {
        TravelDateValue = date;
        await LoadReservedSeatsAsync();
    }

    private async Task LoadReservedSeatsAsync()
    {
        if (Type != "Bus" || !ItemId.HasValue || !TravelDateValue.HasValue)
            return;

        try
        {
            var travelDate = DateOnly.FromDateTime(TravelDateValue.Value);
            var seats = await Http.GetFromJsonAsync<List<string>>(
                $"api/bus/{ItemId}/reserved-seats?travelDate={travelDate:yyyy-MM-dd}");

            ReservedSeats = seats ?? new();
            ReservedSeatsKey++;

            SelectedSeats = SelectedSeats
                .Where(s => !ReservedSeats.Contains(s, StringComparer.OrdinalIgnoreCase))
                .ToList();
        }
        catch
        {
            ReservedSeats = new();
        }
    }

    // --- Premium Hotel Booking Custom Logic & Data Pools ---
    private bool isWishlisted = false;
    private bool isLightboxOpen = false;
    private string lightboxTab = "Property";
    private string lightboxCategory = "All";
    private string activeTab = "Overview";
    private Dictionary<long, int> roomImageIndices = new();

    private void ToggleWishlist()
    {
        isWishlisted = !isWishlisted;
        if (isWishlisted)
            Snackbar.Add("Added hotel to your Wishlist!", Severity.Success);
        else
            Snackbar.Add("Removed hotel from your Wishlist.", Severity.Info);
    }

    private void OpenLightbox(string category = "All")
    {
        lightboxCategory = category;
        lightboxTab = (category == "Guest") ? "Guest" : "Property";
        isLightboxOpen = true;
    }

    private void CloseLightbox()
    {
        isLightboxOpen = false;
    }

    private int GetRoomImageIndex(long roomId)
    {
        if (!roomImageIndices.TryGetValue(roomId, out var index))
        {
            index = (int)(roomId % 8);
            roomImageIndices[roomId] = index;
        }
        return index;
    }

    private void NextRoomImage(long roomId)
    {
        var current = GetRoomImageIndex(roomId);
        roomImageIndices[roomId] = (current + 1) % 8;
    }

    private void PrevRoomImage(long roomId)
    {
        var current = GetRoomImageIndex(roomId);
        roomImageIndices[roomId] = (current - 1 + 8) % 8;
    }

    private void SelectHotelRoom(long roomId)
    {
        OnRoomSelected(roomId);
        Snackbar.Add($"Selected {hotelData?.RoomTypeName} (MMK {hotelData?.PricePerNight:N0}/night). Checkout details unlocked below!", Severity.Success);
