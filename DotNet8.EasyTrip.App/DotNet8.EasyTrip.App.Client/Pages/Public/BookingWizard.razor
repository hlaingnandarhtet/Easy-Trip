                        </div>

                        @if (Type == "Bus" && busData != null)
                        {
                            <div class="booking-service-card">
                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@busData.BusName</MudText>
                                    <MudText Typo="Typo.caption" Class="service-route">@busData.StartPoint to @busData.EndPoint</MudText>
                                </div>
                                <div class="service-price">
                                    <strong>@PricePerSeat.ToString("N0") mmk</strong>
                                    <span>per seat</span>
                                </div>
