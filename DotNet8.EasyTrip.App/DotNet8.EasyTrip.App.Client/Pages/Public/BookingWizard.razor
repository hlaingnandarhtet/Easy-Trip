@page "/booking/wizard"
@layout DotNet8.EasyTrip.App.Client.Layout.PublicLayout
@using MudBlazor
@using DotNet8.EasyTripBackendApi.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-12">
    @if (isLoading)
    {
        <div class="d-flex justify-center align-center py-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
    }
    else if (IsBookingConfirmed)
    {
        <MudPaper Class="pa-8 text-center mx-auto" Style="max-width: 500px;" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 4rem;" Class="mb-3" />
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Booking Confirmed!</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
                Your booking is placed. Details sent to <strong>@GuestEmail</strong>. 
                Pending admin approval.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/my-bookings" Class="px-8">
                View Bookings
            </MudButton>
        </MudPaper>
    }
    else
    {
        @if (Type == "Hotel" && hotelResponseData != null)
        {
            <!-- Breadcrumbs -->
            <div class="hotel-breadcrumbs">
                <a href="/">Home</a>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="font-size: 0.8rem; margin: 0 4px;" />
                <a href="/?tab=Hotel">Hotels</a>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="font-size: 0.8rem; margin: 0 4px;" />
                <span style="color: #0f172a; font-weight: 500;">@hotelResponseData.HotelName</span>
            </div>

            <!-- Premium Photo Gallery Grid -->
            <div class="hotel-gallery-container">
                <div class="hotel-gallery-grid">
                    <div class="gallery-item large" @onclick='() => OpenLightbox("Property")'>
                        <img src="@hotelBuildingImages[0]" alt="Hotel Exterior" />
                        <button class="btn-see-all-photos" type="button">
                            <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
                            <span>See all photos</span>
                        </button>
                    </div>
                    <div class="gallery-item" @onclick='() => OpenLightbox("Rooms")'>
                        <img src="@hotelRoomImages[0]" alt="Deluxe Room" />
                        <button class="wishlist-btn" type="button" @onclick:stopPropagation @onclick="ToggleWishlist">
                            <MudIcon Icon="@(isWishlisted ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)" 
                                     Color="@(isWishlisted ? Color.Error : Color.Default)" Size="Size.Small" />
                        </button>
                    </div>
                    <div class="gallery-item" @onclick='() => OpenLightbox("Facilities")'>
                        <img src="@hotelFacilityImages[0]" alt="Swimming Pool" />
                    </div>
                    <div class="gallery-item" @onclick='() => OpenLightbox("Facilities")'>
                        <img src="@hotelFacilityImages[1]" alt="Lounge Area" />
                    </div>
                    <div class="gallery-item" @onclick='() => OpenLightbox("Guest")'>
                        <img src="@hotelRoomImages[1]" alt="Guest View" />
                        <div class="guest-photo-overlay">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Medium" Class="mb-1" />
                            <span style="font-weight: 700; font-size: 0.95rem;">+24 Guest photos</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky Tab Navigation Bar -->
            <div class="hotel-nav-tabs-wrapper">
                <div class="hotel-nav-tabs-container">
                    <div class="hotel-nav-tabs">
                        <a class="hotel-tab-link @(activeTab == "Overview" ? "active" : "")" @onclick='() => activeTab = "Overview"'>Overview</a>
                        <a class="hotel-tab-link @(activeTab == "Rooms" ? "active" : "")" @onclick='() => activeTab = "Rooms"'>Rooms</a>
                        <a class="hotel-tab-link @(activeTab == "Facilities" ? "active" : "")" @onclick='() => activeTab = "Facilities"'>Facilities</a>
                        <a class="hotel-tab-link @(activeTab == "Reviews" ? "active" : "")" @onclick='() => activeTab = "Reviews"'>Reviews</a>
                        <a class="hotel-tab-link @(activeTab == "Policies" ? "active" : "")" @onclick='() => activeTab = "Policies"'>Policies</a>
                    </div>
                    <div class="hotel-nav-deal">
                        @if (hotelRooms.Any())
                        {
                            var lowestPrice = hotelRooms.Min(r => r.PricePerNight);
                            <div class="hotel-nav-deal">
                                <div class="price-label">
                                    <span>rooms from</span>
                                    <div class="price-value">@lowestPrice.ToString("N0") mmk</div>
                                </div>
                                <button class="btn-room-book" style="width: auto; padding: 8px 18px; font-size: 0.85rem;" type="button" @onclick='() => activeTab = "Rooms"'>
                                    VIEW THIS DEAL
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Header Info & Reviews Card -->
            <div class="hotel-header-grid mt-6">
                <!-- Left Info Section -->
                <div class="hotel-header-info">
                    <div class="hotel-badges-row">
                        <span class="hotel-tag hotel-tag-purple">VISIT MYANMAR 2026</span>
                        <span class="hotel-tag hotel-tag-orange">Top Value</span>
                        <span class="hotel-tag hotel-tag-red">Best seller</span>
                        <span class="hotel-tag hotel-tag-gold">
                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Size="Size.Small" Style="font-size: 1rem;" />
                            2026
                        </span>
                    </div>

                    <div class="d-flex align-center flex-wrap">
                        <MudText Typo="Typo.h4" Style="font-weight: 850; color: #0f172a;">@hotelResponseData.HotelName</MudText>
                        <div class="hotel-stars">
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Filled.StarHalf" Size="Size.Small" />
                        </div>
                    </div>

                    <div class="hotel-address-row mt-3">
                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="color: #64748b;" />
                        <span>@hotelResponseData.Location, Myanmar</span>
                        <span style="color: #cbd5e1;">|</span>
                        <a class="map-link" @onclick='() => OpenLightbox("Property")'>SEE MAP</a>
                    </div>
                </div>

                <!-- Right Review Card -->
                <div class="review-dashboard-card">
                    <div class="review-dashboard-header">
                        <div>
                            <span class="review-rating-label">8.9 Excellent</span>
                            <span class="review-count-sub">53,745 reviews</span>
                        </div>
                        <div class="review-score-bubble">8.9</div>
                    </div>
                    <div class="review-subscores-grid">
                        <div class="subscore-item">Location <span class="subscore-value">9.6</span></div>
                        <div class="subscore-item">Cleanliness <span class="subscore-value">9.2</span></div>
                        <div class="subscore-item">Value for money <span class="subscore-value">9.2</span></div>
                        <div class="subscore-item">Service <span class="subscore-value">9.0</span></div>
                    </div>
                    <div class="review-read-all d-flex justify-space-between align-center">
                        <a class="review-read-all" style="cursor:pointer;" @onclick='() => OpenLightbox("Guest")'>Read all reviews</a>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Primary" />
                    </div>
                    <div class="review-testimonial-bubble mt-3">
                        "Above all, the excellent location was a huge advantage."
                    </div>
                </div>
            </div>

            <!-- Sold Out Warning Banner -->
            <div class="soldout-warning-banner mt-4">
                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Medium" />
                <span>Hurry up! 3 room types have already sold out for your dates!</span>
            </div>

            <!-- Rooms Section Header -->
            <div class="d-flex justify-space-between align-center mb-4 mt-6" id="rooms-section">
                <MudText Typo="Typo.h5" Style="font-weight: 800; color: #0f172a;">Available Room Types</MudText>
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">Select a room to checkout</MudChip>
            </div>

            <!-- Rooms Grid Layout -->
            <div class="room-card-container">
                @if (!hotelRooms.Any())
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="rounded-lg">No rooms available for this hotel currently.</MudAlert>
                }
                else
                {
                    @foreach (var room in hotelRooms)
                    {
                        var isSelected = SelectedRoomId == room.Id;
                        
                        // Dynamically determine room characteristics based on room name
                        string rSize = "22 m² / 237 ft²";
                        string rGuests = "Max 2 adults";
                        string rBeds = "1 Double Bed";

                        if (room.RoomTypeName != null)
                        {
                            if (room.RoomTypeName.Contains("Twin", StringComparison.OrdinalIgnoreCase))
                            {
                                rSize = "21 m² / 226 ft²";
                                rGuests = "Max 2 adults";
                                rBeds = "2 Single Beds";
                            }
                            else if (room.RoomTypeName.Contains("Deluxe", StringComparison.OrdinalIgnoreCase) || 
                             room.RoomTypeName.Contains("Double", StringComparison.OrdinalIgnoreCase))
                            {
                                rSize = "28 m² / 301 ft²";
                                rGuests = "Max 2 adults";
                                rBeds = "1 Queen Bed";
                            }
                            else if (room.RoomTypeName.Contains("Family", StringComparison.OrdinalIgnoreCase))
                            {
                                rSize = "36 m² / 387 ft²";
                                rGuests = "Max 4 adults";
                                rBeds = "2 Double Beds";
                            }
                            else if (room.RoomTypeName.Contains("Suite", StringComparison.OrdinalIgnoreCase))
                            {
                                rSize = "48 m² / 516 ft²";
                                rGuests = "Max 2 adults (1 child)";
                                rBeds = "1 King Bed";
                            }

                        }

                        // Determine slide index for room-level slideshow
                        int slideIdx = GetRoomImageIndex(room.Id);
                        
                        <div class="premium-room-card">
                            <!-- Column 1: Gallery Carousel -->
                            <div class="room-left-col">
                                <div class="room-slider-wrapper">
                                    <img class="room-slider-image" src="@hotelRoomImages[slideIdx]" alt="Room Image" />
                                    <button class="room-slider-btn prev" type="button" @onclick="() => PrevRoomImage(room.Id)">
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowBackIos" Size="Size.Small" Style="margin-left: 6px; font-size: 0.9rem;" />
                                    </button>
                                    <button class="room-slider-btn next" type="button" @onclick="() => NextRoomImage(room.Id)">
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" Style="font-size: 0.9rem;" />
                                    </button>
                                    <div class="room-slider-counter">@(slideIdx + 1) / 8</div>
                                </div>
                                <a class="room-details-link" @onclick='() => OpenLightbox("Rooms")'>Room photos and details</a>
                            </div>

                            <!-- Column 2: Room Info Specs -->
                            <div class="room-info-col">
                                <div class="room-title-name">@room.RoomTypeName</div>
                                <div class="room-spec-row">
                                    <span class="room-spec-item">
                                        <MudIcon Icon="@Icons.Material.Filled.SquareFoot" Size="Size.Small" Style="font-size: 0.9rem;" />
                                        @rSize
                                    </span>
                                    <span class="room-spec-item">
                                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Style="font-size: 0.9rem;" />
                                        @rGuests
                                    </span>
                                    <span class="room-spec-item">
                                        <MudIcon Icon="@Icons.Material.Filled.KingBed" Size="Size.Small" Style="font-size: 0.9rem;" />
                                        @rBeds
                                    </span>
                                </div>

                                <div class="room-rating-row">
                                    <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" Style="font-size: 0.85rem;" />
                                    <span>9.1 Exceptional room comfort and quality</span>
                                </div>

                                <div class="room-amenity-list mt-2">
                                    <span class="room-amenity-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                                        Private bathroom & shower
                                    </span>
                                    <span class="room-amenity-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                                        Hair dryer & toiletries
                                    </span>
                                    <span class="room-amenity-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                                        Air Conditioning & Soundproofing
                                    </span>
                                    @if (!string.IsNullOrEmpty(room.Amenities))
                                    {
                                        @foreach (var amen in room.Amenities.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="room-amenity-item">
                                                <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                                                @amen.Trim()
                                            </span>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Column 3: Red Promo Banner / Perks -->
                            <div class="room-deal-col">
                                <div class="deal-header-red">Lowest price available!</div>
                                <div class="deal-body-content">
                                    <span class="deal-kid-badge">Your kid can stay for FREE!</span>
                                    <div class="deal-perks-list">
                                        <span class="deal-perk-item">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                            Eco Deals applied
                                        </span>
                                        <span class="deal-perk-item primary-perk">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                            Free entry to Infinity Pool
                                        </span>
                                        <span class="deal-perk-item primary-perk">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                            Free gym & fitness access
                                        </span>
                                        <span class="deal-perk-item">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                            Non-refundable (Special low price)
                                        </span>
                                        <span class="deal-perk-item">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                            Free High-speed WiFi
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Column 4: Pricing and Booking Controls -->
                            <div class="room-price-col">
                                @* <div class="original-price-cross">@((room.PricePerNight * 1.3m).ToString("N0")) mmk</div>
                                <div class="coupon-discount-badge">Save 30% applied</div> *@
                                <div class="actual-price-large">@room.PricePerNight.ToString("N0") mmk</div>
                                <div class="price-night-sub">per night<br />with taxes included</div>
                                
                                <button class="btn-room-book @(isSelected ? "selected-room" : "")" type="button" @onclick="() => SelectHotelRoom(room.Id)">
                                    @(isSelected ? "SELECTED" : "BOOK NOW")
                                </button>
                                <div class="room-book-caption">
                                    <span>Only @room.AvailableRooms rooms left!</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Revealable checkout wizard section once a room is selected -->
            @if (SelectedRoomId.HasValue && hotelData != null)
            {
                <div class="step-2-animation mt-8" id="checkout-form-section">
                    <MudPaper Class="pa-6 border rounded-lg" Elevation="2" Style="background: #ffffff; border: 1px solid #e2e8f0;">
                        <MudGrid Spacing="3">
                            <!-- Left: Guest Details Form -->
                            <MudItem xs="12" md="7">
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Primary" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">Guest details and reservation options</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                    Please supply accurate information. The booking voucher will be sent to the email provided.
                                </MudText>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="GuestName" Label="Full Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="GuestPhone" Label="Phone Number" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="GuestEmail" Label="Email Address" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudDatePicker Date="TravelDateValue" DateChanged="OnTravelDateChanged" Label="Check-in Date" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudNumericField @bind-Value="Quantity" Label="Rooms Quantity" Min="1" Max="@hotelData.AvailableRooms" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                </MudGrid>

                                <!-- Section 3: Payment Details -->
                                <div class="mt-6">
                                    <div class="d-flex align-center mb-4">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Class="mr-2" />
                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Payment details</MudText>
                                    </div>

                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                        Select your payment method, transfer exactly <strong>@TotalAmount.ToString("N0") mmk</strong> to the admin's account and upload the screenshot of the transfer slip.
                                    </MudText>

                                    <!-- Payment Type Selector Cards -->
                                    <div class="d-flex gap-3 mb-4 flex-wrap">
                                        @foreach (var pm in paymentMethods)
                                        {
                                            var isSelected = paymentType == pm.PaymentType;
                                            <div class="payment-method-card @(isSelected ? "selected" : "")" @onclick="() => SelectPaymentMethod(pm)">
                                                <div class="payment-method-header">
                                                    <MudIcon Icon="@(pm.PaymentType switch {
                                                        "kpay" => Icons.Material.Filled.AccountBalance,
                                                        "wave" => Icons.Material.Filled.SendToMobile,
                                                        "aya" => Icons.Material.Filled.AccountBalance,
                                                        _ => Icons.Material.Filled.CreditCard
                                                    })" Color="@(isSelected ? Color.Primary : Color.Default)" Class="mr-2" />
                                                    <span class="payment-method-name">@(pm.PaymentType.ToUpper())</span>
                                                </div>
                                                @if (isSelected)
                                                {
                                                    <span class="check-mark">✓</span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    @if (selectedPaymentMethod != null)
                                    {
                                        <div class="admin-account-info-box pa-4 rounded mb-4" style="background-color: #f8fafc; border-left: 4px solid #3b82f6;">
                                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">Admin Payment Details</MudText>
                                            <div class="d-flex justify-space-between mb-1">
                                                <span style="color: #64748b; font-size: 0.85rem;">Account Name:</span>
                                                <span style="font-weight: 600; font-size: 0.85rem;">@selectedPaymentMethod.AccountName</span>
                                            </div>
                                            <div class="d-flex justify-space-between align-center">
                                                <span style="color: #64748b; font-size: 0.85rem;">Account Number / Phone:</span>
                                                <div class="d-flex align-center gap-1">
                                                    <span style="font-weight: 700; color: #1e3a8a; font-size: 0.95rem;">@selectedPaymentMethod.AccountNumber</span>
                                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" OnClick="CopyAccountNumber" />
                                                </div>
                                            </div>
                                        </div>

                                        <MudGrid Spacing="2">
                                            <MudItem xs="12" sm="6">
                                                <MudTextField @bind-Value="transactionNo" Label="Last Transaction Slip No / Ref No" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Placeholder="Enter reference code or last 6 digits" />
                                            </MudItem>
                                            <MudItem xs="12" sm="6">
                                                <div class="d-flex flex-column">
                                                    <label style="font-size: 0.75rem; color: #64748b; margin-bottom: 4px;">Transfer Slip Screenshot *</label>
                                                    <div class="d-flex align-center gap-2">
                                                        <MudButton HtmlTag="label"
                                                                   Variant="Variant.Outlined"
                                                                   Color="Color.Primary"
                                                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                                                   Style="text-transform: none; border-radius: 8px;">
                                                            Upload Screenshot
                                                            <InputFile id="hotelFileInput" OnChange="OnInputFileChange" hidden accept="image/*" />
                                                        </MudButton>
                                                        @if (isUploadingImage)
                                                        {
                                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                                        }
                                                        else if (!string.IsNullOrEmpty(screenshotFileName))
                                                        {
                                                            <div class="d-flex align-center gap-1">
                                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                                <span style="font-size: 0.8rem; color: #0f172a; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@screenshotFileName</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </MudItem>
                                        </MudGrid>
                                        @if (!string.IsNullOrEmpty(screenshotImage))
                                        {
                                            <div class="mt-4 text-center">
                                                <img src="@screenshotImage" style="max-width: 100%; max-height: 200px; border-radius: 8px; border: 1px solid #cbd5e1; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);" />
                                            </div>
                                        }
                                    }
                                </div>
                            </MudItem>

                            <!-- Right: Order Summary -->
                            <MudItem xs="12" md="5">
                                <div class="pa-4 rounded-lg h-100" style="background-color: #fafafa; border: 1px solid #e2e8f0; display:flex; flex-direction:column; justify-content:space-between;">
                                    <div>
                                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4 border-b pb-2">Booking Summary</MudText>
                                        
                                        <div class="d-flex justify-space-between mb-2">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Hotel</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold text-right" Style="max-width: 180px;">@hotelResponseData.HotelName</MudText>
                                        </div>
                                        <div class="d-flex justify-space-between mb-2">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Room Type</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold text-right">@hotelData.RoomTypeName (x@Quantity)</MudText>
                                        </div>
                                        <div class="d-flex justify-space-between mb-2">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Check-in Date</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@(TravelDateValue?.ToString("dd-MM-yyyy") ?? "-")</MudText>
                                        </div>
                                        <div class="d-flex justify-space-between mb-2 border-b pb-2">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Rate per night</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@hotelData.PricePerNight.ToString("N0") mmk</MudText>
                                        </div>

                                        <div class="d-flex justify-space-between align-center my-4">
                                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Total Amount</MudText>
                                            <MudText Typo="Typo.h5" Color="Color.Primary" Class="font-weight-bold">@TotalAmount.ToString("N0") mmk</MudText>
                                        </div>
                                    </div>

                                    <div>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                                                   DisableElevation="true" Size="Size.Large" Class="py-3"
                                                   OnClick="ConfirmBooking" 
                                                   Disabled="@(!CanConfirm)">
                                            @if (IsSubmitting)
                                            {
                                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                                <span class="ms-2">Processing Booking...</span>
                                            }
                                            else
                                            {
                                                <span>Confirm Booking</span>
                                            }
                                        </MudButton>
                                        
                                        @if (!CanConfirm && !IsSubmitting)
                                        {
                                            <MudText Typo="Typo.caption" Class="d-block text-center mt-2" Color="Color.Error">
