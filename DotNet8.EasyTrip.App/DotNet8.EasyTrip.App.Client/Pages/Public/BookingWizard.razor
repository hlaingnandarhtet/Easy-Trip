                    </div>
                </div>
            }
        }
        else
        {
            <div class="booking-checkout-shell">
                <div class="booking-checkout-hero">
                    <div>
                        <div class="checkout-eyebrow">@Type reservation</div>
                        <MudText Typo="Typo.h4" Class="checkout-hero-title">Complete your booking</MudText>
                        <MudText Typo="Typo.body2" Class="checkout-hero-subtitle">Choose your options, add guest details, then upload your payment proof.</MudText>
                    </div>
                    <div class="checkout-total-pill">
                        <span>Total</span>
                        <strong>@TotalAmount.ToString("N0") mmk</strong>
                    </div>
                </div>

            <MudGrid Spacing="4">
                <!-- Left Column: Options & Guest Info -->
                <MudItem xs="12" md="7" lg="8">
                    <!-- Section 1: Options -->
                    <MudPaper Class="checkout-card mb-4" Elevation="0">
                        <div class="checkout-section-head">
                            <div class="checkout-step-icon">1</div>
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="checkout-section-title">Selection</MudText>
                                <MudText Typo="Typo.caption" Class="checkout-section-note">Pick the trip option you want to reserve.</MudText>
