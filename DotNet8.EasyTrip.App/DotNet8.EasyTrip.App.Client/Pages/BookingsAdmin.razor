    private void OpenEditDialog(BookingResponseModel booking)
    {
        isEditMode = true;
        activeBookingId = booking.Id;
        
        submitModel = new BookingSubmitModel
        {
            UserId = booking.UserId ?? 1,
            BookingType = booking.BookingType,
            Quantity = booking.Details?.Quantity ?? 1,
            TravelDate = booking.TravelDate,
            TotalAmount = booking.TotalAmount,
            PaymentStatus = (int)booking.PaymentStatus,
            BookingStatus = (int)booking.BookingStatus
        };

        selectedTravelDate = booking.TravelDate.ToDateTime(TimeOnly.MinValue);

        if (booking.BookingType == "Bus")
        {
            selectedBusId = booking.Details?.BusId ?? mockBuses.First().Id;
            selectedSeatsList = booking.Details?.SelectedSeats?.Split(',').ToList() ?? new List<string>();
        }
        else if (booking.BookingType == "Hotel")
        {
            selectedHotelRoomId = booking.Details?.HotelRoomId ?? mockHotelRooms.First().Id;
            if (booking.Details?.EndDate != null)
            {
                selectedEndDate = booking.Details.EndDate.Value.ToDateTime(TimeOnly.MinValue);
                submitModel.EndDate = booking.Details.EndDate;
                calculatedNights = (int)(selectedEndDate.Value - selectedTravelDate.Value).TotalDays;
                if (calculatedNights <= 0) calculatedNights = 1;
            }
        }
        else if (booking.BookingType == "Package")
        {
            selectedPackageId = booking.Details?.PackageId ?? mockPackages.First().Id;
        }

        RecalculateTotalAmount();
        isDialogVisible = true;
    }

    private void CloseDialog()
    {
        isDialogVisible = false;
    }

    // Value changed event triggers
    private void OnBookingTypeChanged()
    {
        selectedSeatsList.Clear();
        submitModel.Quantity = 1;
        
        if (submitModel.BookingType == "Bus")
        {
            selectedBusId = mockBuses.First().Id;
        }
        else if (submitModel.BookingType == "Hotel")
        {
            selectedHotelRoomId = mockHotelRooms.First().Id;
            selectedEndDate = selectedTravelDate?.AddDays(1) ?? DateTime.Today.AddDays(1);
            calculatedNights = 1;
        }
        else if (submitModel.BookingType == "Package")
        {
            selectedPackageId = mockPackages.First().Id;
        }

        RecalculateTotalAmount();
    }

    private void OnBusClassChanged() => RecalculateTotalAmount();
    private void OnHotelRoomChanged() => RecalculateTotalAmount();
    private void OnPackageChanged() => RecalculateTotalAmount();
    
    private void OnHotelQuantityChanged(int val)
    {
        submitModel.Quantity = val;
        RecalculateTotalAmount();
    }

    private void OnPackageQuantityChanged(int val)
    {
        submitModel.Quantity = val;
        RecalculateTotalAmount();
    }

    private void OnHotelDateChanged(DateTime? date)
    {
        selectedEndDate = date;
        if (selectedEndDate.HasValue && selectedTravelDate.HasValue)
        {
            calculatedNights = (int)(selectedEndDate.Value - selectedTravelDate.Value).TotalDays;
            if (calculatedNights <= 0)
            {
                calculatedNights = 1;
                selectedEndDate = selectedTravelDate.Value.AddDays(1);
            }
        }
        RecalculateTotalAmount();
    }

    // Dynamically calculate totals matching database expectations
    private void RecalculateTotalAmount()
    {
        if (submitModel.BookingType == "Bus")
        {
            var chosenBus = mockBuses.FirstOrDefault(b => b.Id == selectedBusId);
            if (chosenBus != null)
            {
                submitModel.Quantity = selectedSeatsCount > 0 ? selectedSeatsCount : 1;
                submitModel.TotalAmount = selectedSeatsCount * chosenBus.PricePerSeat;
            }
        }
        else if (submitModel.BookingType == "Hotel")
        {
            var chosenRoom = mockHotelRooms.FirstOrDefault(hr => hr.Id == selectedHotelRoomId);
            if (chosenRoom != null)
            {
                submitModel.TotalAmount = chosenRoom.PricePerNight * calculatedNights * submitModel.Quantity;
            }
        }
        else if (submitModel.BookingType == "Package")
        {
            var chosenPkg = mockPackages.FirstOrDefault(p => p.Id == selectedPackageId);
            if (chosenPkg != null)
            {
                submitModel.TotalAmount = chosenPkg.PricePerPerson * submitModel.Quantity;
            }
        }
    }

    // Submit payload to the API
    private async Task SubmitForm()
    {
        if (submitModel.BookingType == "Bus" && selectedSeatsCount == 0)
        {
            Snackbar.Add("Please select at least one seat from the seating chart.", Severity.Warning);
            return;
        }

        isSaving = true;
        
        // Prepare mapping properties
        submitModel.TravelDate = DateOnly.FromDateTime(selectedTravelDate ?? DateTime.Today);
        
        if (submitModel.BookingType == "Bus")
        {
            submitModel.ItemId = selectedBusId;
            submitModel.SelectedSeats = selectedSeatsJoined;
            submitModel.EndDate = null;
        }
        else if (submitModel.BookingType == "Hotel")
        {
            submitModel.ItemId = selectedHotelRoomId;
            submitModel.SelectedSeats = null;
            submitModel.EndDate = DateOnly.FromDateTime(selectedEndDate ?? DateTime.Today.AddDays(1));
        }
        else if (submitModel.BookingType == "Package")
        {
            submitModel.ItemId = selectedPackageId;
            submitModel.SelectedSeats = null;
            submitModel.EndDate = null;
        }

        try
        {
            HttpResponseMessage response;
            if (isEditMode)
            {
                response = await Http.PutAsJsonAsync($"api/booking/{activeBookingId}/update", submitModel);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/booking/create", submitModel);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(isEditMode ? "Reservation updated successfully!" : "Reservation booked successfully!", Severity.Success);
                isDialogVisible = false;
                await LoadBookingsFromServer();
            }
            else
            {
                var errMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"API Error: {response.ReasonPhrase}. {errMsg}", Severity.Error);
                
                // Fallback action for demo mode
                MockSaveAction();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Web Server unreachable: {ex.Message}. Falling back to demo mock execution.", Severity.Info);
            MockSaveAction();
        }
        finally
        {
            isSaving = false;
        }
    }

    private void MockSaveAction()
    {
        if (isEditMode)
        {
            var match = allBookings.FirstOrDefault(b => b.Id == activeBookingId);
            if (match != null)
            {
                match.BookingType = submitModel.BookingType;
                match.TotalAmount = submitModel.TotalAmount;
                match.TravelDate = submitModel.TravelDate;
                
                if (submitModel.BookingType == "Bus")
                {
                    var bus = mockBuses.FirstOrDefault(b => b.Id == selectedBusId);
                    match.ItemName = $"{bus?.ClassType} ({bus?.Route})";
                    if (match.Details != null)
                    {
                        match.Details.BusId = selectedBusId;
                        match.Details.SelectedSeats = selectedSeatsJoined;
                        match.Details.Quantity = selectedSeatsCount;
                    }
                }
                else if (submitModel.BookingType == "Hotel")
                {
                    var room = mockHotelRooms.FirstOrDefault(r => r.Id == selectedHotelRoomId);
                    match.ItemName = $"{room?.RoomType} at {room?.HotelName}";
                    if (match.Details != null)
                    {
                        match.Details.HotelRoomId = selectedHotelRoomId;
                        match.Details.Quantity = submitModel.Quantity;
                        match.Details.EndDate = submitModel.EndDate;
                    }
                }
                else if (submitModel.BookingType == "Package")
                {
                    var pkg = mockPackages.FirstOrDefault(p => p.Id == selectedPackageId);
                    match.ItemName = pkg?.PackageName;
                    if (match.Details != null)
                    {
                        match.Details.PackageId = selectedPackageId;
                        match.Details.Quantity = submitModel.Quantity;
                    }
                }
            }
        }
        else
        {
            long newId = allBookings.Any() ? allBookings.Max(b => b.Id) + 1 : 1001;
            string itemName = "";
            BookingDetailResponseModel details = new BookingDetailResponseModel();

            if (submitModel.BookingType == "Bus")
            {
                var bus = mockBuses.FirstOrDefault(b => b.Id == selectedBusId);
                itemName = $"{bus?.ClassType} ({bus?.Route})";
                details = new BookingDetailResponseModel { Id = newId + 10, BusId = selectedBusId, BusName = bus?.ClassType, SelectedSeats = selectedSeatsJoined, Quantity = selectedSeatsCount };
            }
            else if (submitModel.BookingType == "Hotel")
            {
                var room = mockHotelRooms.FirstOrDefault(r => r.Id == selectedHotelRoomId);
                itemName = $"{room?.RoomType} at {room?.HotelName}";
                details = new BookingDetailResponseModel { Id = newId + 10, HotelRoomId = selectedHotelRoomId, HotelName = room?.HotelName, HotelRoomTypeName = room?.RoomType, Quantity = submitModel.Quantity, EndDate = submitModel.EndDate };
            }
            else if (submitModel.BookingType == "Package")
            {
                var pkg = mockPackages.FirstOrDefault(p => p.Id == selectedPackageId);
                itemName = pkg?.PackageName ?? "";
                details = new BookingDetailResponseModel { Id = newId + 10, PackageId = selectedPackageId, PackageName = itemName, Quantity = submitModel.Quantity };
            }

            allBookings.Add(new BookingResponseModel
            {
                Id = newId,
                UserId = submitModel.UserId,
                UserName = $"Customer #{submitModel.UserId}",
                UserEmail = $"cust{submitModel.UserId}@easytrip.com",
                BookingType = submitModel.BookingType,
                ItemId = submitModel.ItemId,
                ItemName = itemName,
                TravelDate = submitModel.TravelDate,
                TotalAmount = submitModel.TotalAmount,
                PaymentStatus = PaymentStatus.Unpaid,
                BookingStatus = BookingStatus.Pending,
                Details = details
            });
        }
        
        isDialogVisible = false;
        FilterBookings();
        CalculateMetrics();
        Snackbar.Add(isEditMode ? "Reservation updated locally!" : "Reservation booked locally!", Severity.Success);
    }

    // Popup-based deletion dialog confirmation
    private void ConfirmDelete(BookingResponseModel booking)
    {
        bookingToDelete = booking;
        isDeleteDialogVisible = true;
    }

    private void CancelDelete()
    {
        isDeleteDialogVisible = false;
        bookingToDelete = null;
    }

    private async Task ExecuteDelete()
    {
        if (bookingToDelete == null) return;
        
        var targetId = bookingToDelete.Id;
        isDeleteDialogVisible = false;
        
        try
        {
            var response = await Http.DeleteAsync($"api/booking/{targetId}/delete");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Reservation #{targetId} was successfully deleted.", Severity.Success);
                await LoadBookingsFromServer();
            }
            else
            {
                var errMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Delete Failed: {errMsg}", Severity.Error);
                MockDelete(targetId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"API Connection unreachable: {ex.Message}. Deleting locally for demo.", Severity.Info);
            MockDelete(targetId);
        }
        finally
        {
            bookingToDelete = null;
        }
    }

    private void MockDelete(long id)
    {
        var target = allBookings.FirstOrDefault(b => b.Id == id);
        if (target != null)
        {
            allBookings.Remove(target);
            Snackbar.Add("Reservation deleted locally.", Severity.Success);
            FilterBookings();
            CalculateMetrics();
        }
    }
