    private void CalculateMetrics()
    {
        totalBookingsCount = allBookings.Count;
        totalRevenue = allBookings.Where(b => b.BookingStatus != BookingStatus.Cancelled).Sum(b => b.TotalAmount);
        busCount = allBookings.Count(b => b.BookingType.Equals("Bus", StringComparison.OrdinalIgnoreCase));
        hotelCount = allBookings.Count(b => b.BookingType.Equals("Hotel", StringComparison.OrdinalIgnoreCase));
        packageCount = allBookings.Count(b => b.BookingType.Equals("Package", StringComparison.OrdinalIgnoreCase) || b.BookingType.Equals("TravelPackage", StringComparison.OrdinalIgnoreCase));
    }

    private void FilterBookings()
    {
        if (string.IsNullOrWhiteSpace(searchString))
        {
            filteredBookings = allBookings.OrderByDescending(b => b.Id).ToList();
        }
        else
        {
            filteredBookings = allBookings
                .Where(b => b.Id.ToString().Contains(searchString) || 
                            (b.UserName != null && b.UserName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) ||
                            (b.ItemName != null && b.ItemName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) ||
                            b.BookingType.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(b => b.Id)
                .ToList();
        }
        pageIndex = 1;
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        totalPages = (int)Math.Ceiling((double)filteredBookings.Count / pageSize);
        if (totalPages == 0) totalPages = 1;

        paginatedBookings = filteredBookings
            .Skip((pageIndex - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void PrevPage()
    {
        if (pageIndex > 1)
        {
            pageIndex--;
            UpdatePagination();
        }
    }

    private void NextPage()
    {
        if (pageIndex < totalPages)
        {
            pageIndex++;
            UpdatePagination();
        }
    }

