    private async Task LoadBookingsFromServer()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<PaginationResponse<BookingResponseModel>>("api/booking?pageSize=100");
            if (response != null && response.Data != null)
            {
                allBookings = response.Data.ToList();
            }
            else
            {
                LoadMockData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Could not reach Web API: {ex.Message}. Loading offline high-fidelity UI demonstration mock data.");
            LoadMockData();
        }
        finally
        {
            isLoading = false;
            FilterBookings();
            CalculateMetrics();
        }
    }

