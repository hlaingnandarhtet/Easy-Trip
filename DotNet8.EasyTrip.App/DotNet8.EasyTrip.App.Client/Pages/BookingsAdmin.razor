    // Bus seating selection handlers
    private bool IsSeatOccupied(string seat) => occupiedSeats.Contains(seat);
    
    private Color GetSeatColor(string seat)
    {
        if (IsSeatOccupied(seat)) return Color.Error;
        if (selectedSeatsList.Contains(seat)) return Color.Success;
        return Color.Default;
    }

    private Variant GetSeatVariant(string seat)
    {
        if (selectedSeatsList.Contains(seat)) return Variant.Filled;
        return Variant.Outlined;
    }

    private void ToggleSeat(string seat)
    {
        if (IsSeatOccupied(seat)) return;

        if (selectedSeatsList.Contains(seat))
            selectedSeatsList.Remove(seat);
        else
            selectedSeatsList.Add(seat);

        RecalculateTotalAmount();
    }

