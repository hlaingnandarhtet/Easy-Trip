@page "/bookings"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section with sleek gradient background -->
    <MudPaper Class="p-6 mb-8 rounded-lg d-flex justify-between align-center" 
              Style="background: linear-gradient(135deg, #1f2937 0%, #111827 100%); color: white; border-left: 6px solid #594ae2;">
        <div>
            <MudText Typo="Typo.h4" Class="font-bold mb-1" Style="font-weight: 800; letter-spacing: -0.5px;">Booking Management</MudText>
            <MudText Typo="Typo.body2" Style="color: #9ca3af;">Manage customer reservations, track financial metrics, and book new itineraries dynamically.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add"
                   Size="Size.Large"
                   OnClick="OpenCreateDialog"
                   Style="background: linear-gradient(90deg, #594ae2 0%, #7c3aed 100%); font-weight: 600; text-transform: none; border-radius: 8px; box-shadow: 0 4px 14px rgba(89, 74, 226, 0.4);">
            New Booking
        </MudButton>
    </MudPaper>

    <!-- Dashboard Metrics Cards -->
    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="p-5 rounded-lg border border-gray-200" Elevation="2" Style="border-radius: 12px; transition: transform 0.2s ease;">
                <div class="d-flex justify-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Total Bookings</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 800; color: #1e293b;">@totalBookingsCount</MudText>
                    </div>
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="height: 48px; width: 48px; border-radius: 8px;">
                        <MudIcon Icon="@Icons.Material.Filled.BookOnline" />
                    </MudAvatar>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="p-5 rounded-lg border border-gray-200" Elevation="2" Style="border-radius: 12px;">
                <div class="d-flex justify-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Total Revenue</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 800; color: #10b981;">@totalRevenue.ToString("N0") MMK</MudText>
                    </div>
                    <MudAvatar Color="Color.Success" Variant="Variant.Filled" Style="height: 48px; width: 48px; border-radius: 8px;">
                        <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" />
                    </MudAvatar>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="p-5 rounded-lg border border-gray-200" Elevation="2" Style="border-radius: 12px;">
                <div class="d-flex justify-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Bus Reservations</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 800; color: #f59e0b;">@busCount</MudText>
                    </div>
                    <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Style="height: 48px; width: 48px; border-radius: 8px;">
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" />
                    </MudAvatar>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="p-5 rounded-lg border border-gray-200" Elevation="2" Style="border-radius: 12px;">
                <div class="d-flex justify-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Hotel & Packages</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 800; color: #6366f1;">@(hotelCount + packageCount)</MudText>
                    </div>
                    <MudAvatar Color="Color.Info" Variant="Variant.Filled" Style="height: 48px; width: 48px; border-radius: 8px;">
                        <MudIcon Icon="@Icons.Material.Filled.CardTravel" />
                    </MudAvatar>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Data Table & Search Section -->
    <MudPaper Class="p-6 rounded-lg border border-gray-200" Elevation="3" Style="border-radius: 12px;">
        <div class="d-flex justify-between align-center mb-6">
            <MudText Typo="Typo.h6" Style="font-weight: 700;">Reservation Directory</MudText>
            <div class="d-flex gap-3 align-center" style="width: 400px;">
                <MudTextField @bind-Value="searchString" 
                              Placeholder="Search customer, item, or ID..." 
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search" 
                              IconSize="Size.Medium" 
                              Class="mt-0"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Secondary" 
                           OnClick="() => FilterBookings()"
                           Style="height: 40px; text-transform: none; font-weight: 600; border-radius: 6px;">
                    Search
                </MudButton>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="d-flex justify-center my-12 align-center gap-3">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="text-secondary">Retrieving bookings from server...</MudText>
            </div>
        }
        else if (filteredBookings == null || !filteredBookings.Any())
        {
            <div class="text-center py-12 border border-dashed rounded-lg bg-gray-50 d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Color="Color.Default" Size="Size.Large" Style="font-size: 64px;" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="font-bold text-secondary mb-1">No Bookings Found</MudText>
                <MudText Typo="Typo.body2" Class="text-muted mb-4">There are currently no reservations matching your filters or recorded in the database.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog">Add Your First Booking</MudButton>
            </div>
        }
        else
        {
            <MudTable Items="@paginatedBookings" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="border border-gray-100 rounded-lg">
                <HeaderContent>
                    <MudTh Style="font-weight: 700;">ID</MudTh>
                    <MudTh Style="font-weight: 700;">Customer</MudTh>
                    <MudTh Style="font-weight: 700;">Type</MudTh>
                    <MudTh Style="font-weight: 700;">Booked Item</MudTh>
                    <MudTh Style="font-weight: 700;">Travel Date</MudTh>
                    <MudTh Style="font-weight: 700;">Total Amount</MudTh>
                    <MudTh Style="font-weight: 700;">Payment Status</MudTh>
                    <MudTh Style="font-weight: 700;">Booking Status</MudTh>
                    <MudTh Style="font-weight: 700; text-align: center;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="ID"><strong>#@context.Id</strong></MudTd>
                    <MudTd DataLabel="Customer">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2" Class="font-semibold">@(context.UserName ?? $"User #{context.UserId}")</MudText>
                            <MudText Typo="Typo.caption" Class="text-muted">@(context.UserEmail ?? "no-email@easytrip.com")</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Color="@GetBookingTypeColor(context.BookingType)" Size="Size.Small" Style="font-weight: 600;">@context.BookingType</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Booked Item">@(context.ItemName ?? "Multiple/Complex Detail")</MudTd>
                    <MudTd DataLabel="Travel Date">@context.TravelDate.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="Total Amount"><strong style="color: #10b981;">@context.TotalAmount.ToString("N0") MMK</strong></MudTd>
                    <MudTd DataLabel="Payment Status">
                        <MudChip T="string" Color="@GetPaymentStatusColor(context.PaymentStatus)" Variant="Variant.Text" Size="Size.Small" Style="font-weight: 700;">@context.PaymentStatus.ToString()</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Booking Status">
                        <MudChip T="string" Color="@GetBookingStatusColor(context.BookingStatus)" Size="Size.Small" Style="font-weight: 600;">@context.BookingStatus.ToString()</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: center;">
                        <div class="d-flex justify-center gap-1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="() => OpenEditDialog(context)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => ConfirmDelete(context)" />
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination Toolbar -->
            <div class="d-flex justify-between align-center mt-6">
                <MudText Typo="Typo.caption" Class="text-secondary">Showing @(((pageIndex - 1) * pageSize) + 1) to @(Math.Min(pageIndex * pageSize, filteredBookings.Count)) of @filteredBookings.Count bookings</MudText>
                <div class="d-flex align-center gap-2">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Disabled="@(pageIndex == 1)" OnClick="PrevPage" />
                    <MudText Typo="Typo.body2" Class="font-bold">Page @pageIndex of @totalPages</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@(pageIndex == totalPages)" OnClick="NextPage" />
                </div>
            </div>
        }
    </MudPaper>
</MudContainer>

<!-- Dynamic CRUD MudDialog Structure -->
<MudDialog @bind-Visible="isDialogVisible" Options="dialogOptions" Style="border-radius: 16px; overflow: hidden; max-width: 650px; width: 100%;">
    <TitleContent>
        <div class="d-flex align-center gap-2 py-2">
            <MudIcon Icon="@(isEditMode ? Icons.Material.Filled.EditCalendar : Icons.Material.Filled.AddModerator)" Color="Color.Primary" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Style="font-weight: 700;">@(isEditMode ? $"Modify Reservation #{activeBookingId}" : "Create A New Booking")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@submitModel" @ref="form" Class="py-2">
            <MudGrid Spacing="3">
                <!-- Row 1: Booking Type & Travel Date -->
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Booking Category" @bind-Value="submitModel.BookingType" SelectedValuesChanged="OnBookingTypeChanged" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="@("Bus")">🚌 Bus Transport</MudSelectItem>
                        <MudSelectItem Value="@("Hotel")">🏨 Hotel Lodging</MudSelectItem>
                        <MudSelectItem Value="@("Package")">📦 Travel Package</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Travel/Check-in Date" @bind-Date="selectedTravelDate" Required="true" Variant="Variant.Outlined" />
                </MudItem>

                <!-- DYNAMIC FIELDS BASED ON BOOKING TYPE -->
                @if (submitModel.BookingType == "Bus")
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="font-bold text-secondary mb-2">Bus Class & Route Details</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect T="long" Label="Select Bus Class & Route" @bind-Value="selectedBusId" SelectedValuesChanged="OnBusClassChanged" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var bus in mockBuses)
                            {
                                <MudSelectItem Value="@bus.Id">@($"{bus.Route} - {bus.ClassType} ({bus.PricePerSeat:N0} MMK)")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @if (selectedBusId > 0)
                    {
                        var chosenBus = mockBuses.FirstOrDefault(b => b.Id == selectedBusId);
                        <MudItem xs="12">
                            <MudPaper Class="p-4 bg-gray-50 border rounded-lg" Elevation="0">
                                <div class="d-flex justify-between align-center mb-3">
                                    <MudText Typo="Typo.body2" Class="font-bold">🚌 Click to Select Seats (@(chosenBus?.ClassType))</MudText>
                                    <div class="d-flex gap-2">
                                        <span class="d-flex align-center gap-1"><MudIcon Icon="@Icons.Material.Filled.Square" Color="Color.Success" Size="Size.Small" />Selected</span>
                                        <span class="d-flex align-center gap-1"><MudIcon Icon="@Icons.Material.Filled.Square" Color="Color.Default" Size="Size.Small" />Available</span>
                                        <span class="d-flex align-center gap-1"><MudIcon Icon="@Icons.Material.Filled.Square" Color="Color.Error" Size="Size.Small" />Occupied</span>
                                    </div>
                                </div>

                                <!-- Custom Bus Seating Chart Design -->
                                <div class="bus-container mx-auto p-4 rounded-xl border border-slate-300 relative bg-white" 
                                     style="max-width: 320px; border: 2px solid #cbd5e1; border-radius: 12px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);">
                                    
                                    <!-- Front/Dashboard -->
                                    <div class="d-flex justify-between align-center border-b pb-3 mb-4 text-slate-400">
                                        <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Medium" Style="transform: rotate(45deg); color: #94a3b8;" />
                                        <MudText Typo="Typo.caption" Class="uppercase font-bold tracking-wider">Front of Bus / Driver</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.SportsScore" Size="Size.Medium" />
                                    </div>

                                    <!-- Grid Layout based on ClassType -->
                                    @if (chosenBus?.ClassType.Contains("VIP") == true)
                                    {
                                        <!-- VIP 2+1 Layout (3 seats per row) -->
                                        <div class="d-flex flex-column gap-3">
                                            @for (int r = 1; r <= 6; r++)
                                            {
                                                var rowChar = (char)('A' + r - 1);
                                                <div class="d-flex justify-between align-center">
                                                    <!-- Left Seat -->
                                                    <div style="width: 45px;">
                                                        @{ var seat1 = $"{rowChar}1"; }
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat1)" 
                                                                 Color="@GetSeatColor(seat1)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat1)"
                                                                 OnClick="() => ToggleSeat(seat1)" 
                                                                 Class="ma-0 w-100 font-bold">@seat1</MudChip>
                                                    </div>

                                                    <!-- Middle Aisle -->
                                                    <div style="width: 30px;" class="text-center text-slate-300 font-semibold">|</div>

                                                    <!-- Right 2 Seats -->
                                                    <div class="d-flex gap-2">
                                                        @{ 
                                                            var seat2 = $"{rowChar}2"; 
                                                            var seat3 = $"{rowChar}3"; 
                                                        }
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat2)" 
                                                                 Color="@GetSeatColor(seat2)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat2)"
                                                                 OnClick="() => ToggleSeat(seat2)" 
                                                                 Class="ma-0 font-bold">@seat2</MudChip>
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat3)" 
                                                                 Color="@GetSeatColor(seat3)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat3)"
                                                                 OnClick="() => ToggleSeat(seat3)" 
                                                                 Class="ma-0 font-bold">@seat3</MudChip>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- Standard 2+2 Layout (4 seats per row) -->
                                        <div class="d-flex flex-column gap-3">
                                            @for (int r = 1; r <= 6; r++)
                                            {
                                                var rowChar = (char)('A' + r - 1);
                                                <div class="d-flex justify-between align-center">
                                                    <!-- Left 2 Seats -->
                                                    <div class="d-flex gap-2">
                                                        @{ 
                                                            var seat1 = $"{rowChar}1"; 
                                                            var seat2 = $"{rowChar}2"; 
                                                        }
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat1)" 
                                                                 Color="@GetSeatColor(seat1)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat1)"
                                                                 OnClick="() => ToggleSeat(seat1)" 
                                                                 Class="ma-0 font-bold">@seat1</MudChip>
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat2)" 
                                                                 Color="@GetSeatColor(seat2)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat2)"
                                                                 OnClick="() => ToggleSeat(seat2)" 
                                                                 Class="ma-0 font-bold">@seat2</MudChip>
                                                    </div>

                                                    <!-- Aisle -->
                                                    <div style="width: 20px;" class="text-center text-slate-300 font-semibold">|</div>

                                                    <!-- Right 2 Seats -->
                                                    <div class="d-flex gap-2">
                                                        @{ 
                                                            var seat3 = $"{rowChar}3"; 
                                                            var seat4 = $"{rowChar}4"; 
                                                        }
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat3)" 
                                                                 Color="@GetSeatColor(seat3)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat3)"
                                                                 OnClick="() => ToggleSeat(seat3)" 
                                                                 Class="ma-0 font-bold">@seat3</MudChip>
                                                        <MudChip T="string" 
                                                                 Variant="@GetSeatVariant(seat4)" 
                                                                 Color="@GetSeatColor(seat4)" 
                                                                 Size="Size.Small" 
                                                                 Disabled="@IsSeatOccupied(seat4)"
                                                                 OnClick="() => ToggleSeat(seat4)" 
                                                                 Class="ma-0 font-bold">@seat4</MudChip>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="mt-3 d-flex justify-between align-center">
                                    <MudText Typo="Typo.body2">Selected: <strong>@(string.IsNullOrEmpty(selectedSeatsJoined) ? "None" : selectedSeatsJoined)</strong></MudText>
                                    <MudText Typo="Typo.body2">Seats Count: <strong>@selectedSeatsCount</strong></MudText>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                }
                else if (submitModel.BookingType == "Hotel")
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="font-bold text-secondary mb-2">Lodging & Rooms Details</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="long" Label="Select Room Class" @bind-Value="selectedHotelRoomId" SelectedValuesChanged="OnHotelRoomChanged" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var room in mockHotelRooms)
                            {
                                <MudSelectItem Value="@room.Id">@($"{room.HotelName} - {room.RoomType} ({room.PricePerNight:N0} MMK/night)")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Check-out Date" Date="selectedEndDate" DateChanged="OnHotelDateChanged" Required="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" Label="Number of Rooms" Value="submitModel.Quantity" ValueChanged="OnHotelQuantityChanged" Min="1" Max="10" Required="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6" Class="d-flex align-center">
                        <MudText Typo="Typo.body2" Class="mt-2 text-slate-500">Calculated Stay Duration: <strong class="text-slate-800">@calculatedNights Nights</strong></MudText>
                    </MudItem>
                }
                else if (submitModel.BookingType == "Package")
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="font-bold text-secondary mb-2">Vacation Package Configuration</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="long" Label="Select Tour Package" @bind-Value="selectedPackageId" SelectedValuesChanged="OnPackageChanged" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var pkg in mockPackages)
                            {
                                <MudSelectItem Value="@pkg.Id">@($"{pkg.PackageName} ({pkg.PricePerPerson:N0} MMK)")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" Label="Headcount / Travelers" Value="submitModel.Quantity" ValueChanged="OnPackageQuantityChanged" Min="1" Max="20" Required="true" Variant="Variant.Outlined" />
                    </MudItem>
                }

                <!-- Total Amount & Footer -->
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="submitModel.UserId" Label="Customer User ID" InputType="InputType.Number" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" @bind-Value="submitModel.TotalAmount" Label="Total Booking Amount (MMK)" Disabled="true" Required="true" Variant="Variant.Filled" Style="color: #10b981; font-weight: bold; font-size: 1.15rem;" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseDialog" Style="text-transform: none; font-weight: 600;">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="SubmitForm" 
                   Disabled="isSaving"
                   Style="background: linear-gradient(90deg, #594ae2 0%, #7c3aed 100%); text-transform: none; font-weight: 600; border-radius: 8px;">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Saving Booking...</span>
            }
            else
            {
                <span>Confirm Reservation</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Custom Delete Confirmation Dialog -->
<MudDialog @bind-Visible="isDeleteDialogVisible" Options="dialogOptions" Style="border-radius: 12px; max-width: 420px; width: 100%;">
    <TitleContent>
        <div class="d-flex align-center gap-2 py-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Style="font-weight: 700;">Cancel Reservation?</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to permanently delete and cancel booking <strong>#@bookingToDelete?.Id</strong> for <strong>@bookingToDelete?.UserName</strong>?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelDelete" Style="text-transform: none; font-weight: 600;">Keep It</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ExecuteDelete" Style="text-transform: none; font-weight: 600; border-radius: 8px;">Delete It</MudButton>
    </DialogActions>
</MudDialog>

@code {
    // API States & Collections
    private List<BookingResponseModel> allBookings = new List<BookingResponseModel>();
    private List<BookingResponseModel> filteredBookings = new List<BookingResponseModel>();
    private List<BookingResponseModel> paginatedBookings = new List<BookingResponseModel>();
    
    // Pagination & Search States
    private bool isLoading = false;
    private string searchString = "";
    private int pageIndex = 1;
    private int pageSize = 7;
    private int totalPages = 1;

    // Dashboard metrics
    private int totalBookingsCount = 0;
    private decimal totalRevenue = 0;
    private int busCount = 0;
    private int hotelCount = 0;
    private int packageCount = 0;

    // Dialog state
    private bool isDialogVisible = false;
