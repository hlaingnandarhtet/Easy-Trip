@page "/payment-methods"
@inherits ComponentBase
@rendermode InteractiveWebAssembly

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="et-page">
    <PageHeader Title="Payment Method Management"
                Subtitle="Manage payment providers, merchant accounts, and numbers."
                Icon="@Icons.Material.Filled.Payments">
        <Actions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="et-btn-primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePage">
                Add Payment Method
            </MudButton>
        </Actions>
    </PageHeader>

    <MudPaper Class="et-table-card" Elevation="0">
        <div class="et-table-toolbar">
            <div class="d-flex align-center gap-3 flex-wrap w-100">
                <MudTextField T="string" @bind-Value="_searchString" Label="Payment Provider / Account"
                               Placeholder="Search payment provider..." Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Clearable="true"
                               Style="min-width: 260px; max-width: 420px; flex: 1;" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="et-btn-primary"
                             OnClick="PerformSearch" StartIcon="@Icons.Material.Filled.Search" Style="height: 40px; text-transform: none; font-weight: 600; border-radius: 10px;">
                    Search
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ResetFilters"
                           Style="height: 40px; border-radius: 10px; text-transform: none; font-weight: 600;" StartIcon="@Icons.Material.Filled.Clear">
                    Reset
                </MudButton>
            </div>
        </div>

        <MudTable T="PaymentMethodResponseModel" Items="_filteredList" Hover="true" Dense="false"
                  Striped="false" Elevation="0" Class="et-data-table">
            <HeaderContent>
                <MudTh Style="width: 56px;">No.</MudTh>
                <MudTh>Payment Provider</MudTh>
                <MudTh>Account Name</MudTh>
                <MudTh>Account Number</MudTh>
                <MudTh Style="text-align: right; width: 150px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="No."><span class="et-row-no">@GetRowNumber(context)</span></MudTd>
                <MudTd DataLabel="Payment Provider">
                    <MudText Style="font-weight: 700; color: #0F172A; text-transform: uppercase;">@context.PaymentType</MudText>
                </MudTd>
                <MudTd DataLabel="Account Name">
                    <MudText Style="color: #475569;">@context.AccountName</MudText>
                </MudTd>
                <MudTd DataLabel="Account Number">
                    <MudText Style="font-family: monospace; color: #0F172A; font-weight: 600;">@context.AccountNumber</MudText>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Edit Payment Method">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="et-action-btn et-action-btn--edit"
                                       OnClick="@(() => OpenEditPage(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete Payment Method">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Class="et-action-btn et-action-btn--delete ml-1"
                                       OnClick="@(() => OpenDeleteDialog(context.Id))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="et-empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" Style="opacity: 0.4;" />
                    <MudText Typo="Typo.h6" Class="mt-3" Style="font-weight: 700;">No payment methods found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Try another search or register a payment method.</MudText>
                </div>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager InfoFormat="{first_item}-{last_item} of {all_items}" HorizontalAlignment="HorizontalAlignment.Right" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>
