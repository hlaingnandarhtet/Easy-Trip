@page "/room-type/edit/{Id:long}"
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudContainer Class="et-form-page">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="Cancel" Class="mb-3 et-btn-ghost">
        Back to room types
    </MudButton>

    <MudPaper Class="et-form-card" Elevation="0">
        <div class="et-form-card__hero">
            <MudText Typo="Typo.h5" Style="font-weight: 800;">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                Edit Room Type
            </MudText>
        </div>

        @if (_isLoading)
        {
            <div class="d-flex justify-center align-center py-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_success">
                <div class="et-form-section pb-4">
                    <div class="et-form-section__title">Room type details</div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="12">
                            <MudTextField T="string" Label="Room Type Name" Required="true" RequiredError="Room type name is required"
                                           @bind-Value="_roomTypeModel.TypeName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                </div>
            </MudForm>
        }

        <div class="et-form-actions">
            <MudButton Variant="Variant.Outlined" OnClick="Cancel" Class="et-btn-ghost" Disabled="_isSaving">Cancel</MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@(!_success || _isSaving || _isLoading)" Class="et-btn-primary">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save Changes
            </MudButton>
        </div>
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public long Id { get; set; }

    private RoomTypeRequestModel _roomTypeModel = new();
    private bool _success = false;
    private bool _isLoading = true;
    private bool _isSaving = false;
    private MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<RoomTypeResponseModel>($"api/roomtype/{Id}");
            if (response != null)
            {
                _roomTypeModel = new RoomTypeRequestModel
                {
                    TypeName = response.TypeName
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading room type: {ex.Message}", Severity.Error);
            Nav.NavigateTo("/room-type");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/room-type");

    private async Task Submit()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        _isSaving = true;
        try
        {
            var response = await Http.PutAsJsonAsync($"api/roomtypes/{Id}", _roomTypeModel);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Room Type updated successfully!", Severity.Success);
                Nav.NavigateTo("/room-type");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to update room type: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }
}
