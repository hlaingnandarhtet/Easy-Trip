@page "/admin-buses"
@namespace DotNet8.EasyTrip.App.Client.Pages
@using DotNet8.EasyTrip.App.Client.Components
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <MudPaper Class="p-6 mb-8 rounded-lg d-flex justify-between align-center" 
              Style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; border-left: 6px solid #3b82f6;">
        <div>
            <MudText Typo="Typo.h4" Class="font-bold mb-1" Style="font-weight: 800; letter-spacing: -0.5px;">Bus Fleet Management</MudText>
            <MudText Typo="Typo.body2" Style="color: #94a3b8;">Establish routes, configure seating plans, and adjust ticket prices for the Easy-Trip transport catalog.</MudText>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Info" 
                       Size="Size.Medium" 
                       Href="/admin-dashboard"
                       StartIcon="@Icons.Material.Filled.Dashboard"
                       Style="border-radius: 8px; text-transform: none; font-weight: 600;">
                Go to Dashboard
            </MudButton>
        </div>
    </MudPaper>

    <!-- Main Table Container -->
    <MudPaper Class="p-6 rounded-lg border border-gray-200" Elevation="3" Style="border-radius: 16px;">
        
        <!-- Native MudTable Component -->
        <MudTable Items="@filteredBuses" 
                  Loading="@isLoading" 
                  LoadingProgressColor="Color.Primary"
                  Hover="true" 
                  Breakpoint="Breakpoint.Sm" 
                  Elevation="0" 
                  RowsPerPage="10"
                  Class="border border-slate-100 rounded-lg">
            
            <!-- Custom Top Toolbar -->
            <ToolBarContent>
                <div class="d-flex justify-between align-center w-100 gap-4 flex-wrap">
                    <!-- Title Area -->
                    <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1e293b;">Active Transit Inventory</MudText>
                    
                    <!-- Toolbar Controls -->
                    <div class="d-flex align-center gap-3 flex-wrap" style="flex-grow: 1; justify-content: flex-end;">
                        <!-- Search Box -->
                        <MudTextField @bind-Value="searchString" 
                                      Placeholder="Search terminal route, bus plate..." 
                                      Adornment="Adornment.Start" 
                                      AdornmentIcon="@Icons.Material.Filled.Search" 
                                      IconSize="Size.Medium" 
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      OnDebounceIntervalElapsed="FilterInventory"
                                      DebounceInterval="300"
                                      Style="max-width: 320px; width: 100%;" />

                        <!-- Refresh Action Button -->
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.Refresh" 
                                   OnClick="RefreshInventory"
                                   Style="text-transform: none; font-weight: 600; border-radius: 8px; height: 40px;">
                            Refresh
                        </MudButton>

                        <!-- Create New Action Button -->
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.Add" 
                                   OnClick="OpenCreateDialog"
                                   Style="background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%); text-transform: none; font-weight: 600; border-radius: 8px; height: 40px; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);">
                            Create Route
                        </MudButton>
                    </div>
                </div>
            </ToolBarContent>

            <!-- Table Header -->
            <HeaderContent>
                <MudTh Style="font-weight: 700; color: #475569;">ID</MudTh>
                <MudTh Style="font-weight: 700; color: #475569;">Route Description</MudTh>
                <MudTh Style="font-weight: 700; color: #475569;">Operator & License</MudTh>
                <MudTh Style="font-weight: 700; color: #475569;">Bus Class</MudTh>
                <MudTh Style="font-weight: 700; color: #475569;">Status</MudTh>
                <MudTh Style="font-weight: 700; color: #475569;">Ticket Price</MudTh>
                <MudTh Style="font-weight: 700; color: #475569; text-align: center;">Actions</MudTh>
            </HeaderContent>

            <!-- Table Rows -->
            <RowTemplate>
                <MudTd DataLabel="ID"><strong>#@context.Id</strong></MudTd>
                <MudTd DataLabel="Route Description">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.DepartureBoard" Size="Size.Small" Style="color: #3b82f6;" />
                        <MudText Typo="Typo.body2" Class="font-semibold">@context.StartPoint ➡️ @context.EndPoint</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Operator & License">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Class="font-semibold">@context.BusName</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">@context.BusNumber</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Bus Class">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" Style="font-weight: 600;">@context.BusClass</MudChip>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@GetStatusColor(context.BusStatus)" Size="Size.Small" Style="font-weight: bold;">
                        @GetStatusLabel(context.BusStatus)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Ticket Price">
                    <strong style="color: #10b981; font-size: 0.95rem;">@context.Price.ToString("N0") MMK</strong>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: center;">
                    <div class="d-flex justify-center gap-2">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                       Color="Color.Info" 
                                       Size="Size.Small" 
                                       OnClick="() => OpenEditDialog(context)" 
                                       Style="background-color: rgba(6, 182, 212, 0.08);" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                       Color="Color.Error" 
                                       Size="Size.Small" 
                                       OnClick="() => OpenDeleteDialog(context)" 
                                       Style="background-color: rgba(239, 68, 68, 0.08);" />
                    </div>
                </MudTd>
            </RowTemplate>

            <!-- Table Footer with Pagination Controls -->
            <PagerContent>
                <MudTablePager RowsPerPageString="Records per page:" PageSizeOptions="new int[] { 5, 10, 15 }" />
            </PagerContent>

        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    // Data list collections
    private List<BusCrudDialog.BusUiModel> allBuses = new List<BusCrudDialog.BusUiModel>();
    private List<BusCrudDialog.BusUiModel> filteredBuses = new List<BusCrudDialog.BusUiModel>();

    // Operational indicators
    private bool isLoading = false;
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadInventoryFromServer();
    }

    private async Task LoadInventoryFromServer()
    {
        isLoading = true;
        try
        {
            // API GET Call
            var response = await Http.GetFromJsonAsync<PaginationResponse<BusCrudDialog.BusUiModel>>("api/bus?pageSize=100");
            if (response != null && response.Data != null)
            {
                allBuses = response.Data.ToList();
            }
            else
            {
                LoadMockInventory();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API endpoint unreachable: {ex.Message}. Activating high-fidelity offline mock data.");
            LoadMockInventory();
        }
        finally
        {
            isLoading = false;
            FilterInventory();
        }
    }

    private void LoadMockInventory()
    {
        allBuses = new List<BusCrudDialog.BusUiModel>
        {
            new BusCrudDialog.BusUiModel { Id = 1, BusName = "Elite Express", BusNumber = "YGN-7C/1122", BusClass = "Scania VIP 2+1", Price = 30000, StartPoint = "Yangon", EndPoint = "Mandalay", Departure = "2026-05-20", TimeSlot = "08:30 PM", BusStatus = 1 },
            new BusCrudDialog.BusUiModel { Id = 2, BusName = "JJ Express", BusNumber = "YGN-9K/8890", BusClass = "Scania VIP 2+1", Price = 32000, StartPoint = "Yangon", EndPoint = "Bagan", Departure = "2026-05-21", TimeSlot = "09:00 PM", BusStatus = 1 },
            new BusCrudDialog.BusUiModel { Id = 3, BusName = "Famous Express", BusNumber = "YGN-5D/4567", BusClass = "Standard 2+2", Price = 20000, StartPoint = "Yangon", EndPoint = "Naypyitaw", Departure = "2026-05-20", TimeSlot = "07:30 AM", BusStatus = 1 },
            new BusCrudDialog.BusUiModel { Id = 4, BusName = "Mandalar Minn", BusNumber = "MDY-3B/4522", BusClass = "Standard 2+2", Price = 22000, StartPoint = "Mandalay", EndPoint = "Taunggyi", Departure = "2026-05-22", TimeSlot = "09:30 PM", BusStatus = 0 },
            new BusCrudDialog.BusUiModel { Id = 5, BusName = "Elite Express", BusNumber = "YGN-2F/6643", BusClass = "Business VIP 1+1", Price = 45000, StartPoint = "Yangon", EndPoint = "Mandalay", Departure = "2026-05-20", TimeSlot = "09:30 PM", BusStatus = 2 }
        };
    }

    private void FilterInventory()
    {
        if (string.IsNullOrWhiteSpace(searchString))
        {
            filteredBuses = allBuses.OrderByDescending(b => b.Id).ToList();
        }
        else
        {
            filteredBuses = allBuses
                .Where(b => b.BusName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                            b.BusNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                            b.StartPoint.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                            b.EndPoint.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                            b.BusClass.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(b => b.Id)
                .ToList();
        }
    }

    private async Task RefreshInventory()
    {
        searchString = "";
        await LoadInventoryFromServer();
        Snackbar.Add("Fleet inventory synced.", Severity.Info);
    }

    // Color mapper based on status code
    private Color GetStatusColor(int status) => status switch
    {
        1 => Color.Success,
        0 => Color.Warning,
        2 => Color.Error,
        _ => Color.Default
    };

    private string GetStatusLabel(int status) => status switch
    {
        1 => "Active",
        0 => "Maintenance",
        2 => "Suspended",
        _ => "Unknown"
    };

    // Dialog opening hooks
    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<BusCrudDialog>
        {
            { x => x.BusModel, new BusCrudDialog.BusUiModel() }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<BusCrudDialog>("Create New Fleet", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is BusCrudDialog.BusUiModel newBus)
        {
            isLoading = true;
            try
            {
                var response = await Http.PostAsJsonAsync("api/bus/create", newBus);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("New bus route registered successfully!", Severity.Success);
                    await LoadInventoryFromServer();
                }
                else
                {
                    MockSaveLocal(newBus, isNew: true);
                }
            }
            catch (Exception)
            {
                MockSaveLocal(newBus, isNew: true);
            }
            finally
            {
                isLoading = false;
            }
        }
    }

    private async Task OpenEditDialog(BusCrudDialog.BusUiModel model)
    {
        // Clone model to prevent direct mutations
        var clonedModel = new BusCrudDialog.BusUiModel
        {
            Id = model.Id,
            BusName = model.BusName,
            BusNumber = model.BusNumber,
            BusClass = model.BusClass,
            TotalSeats = model.TotalSeats,
            Price = model.Price,
            StartPoint = model.StartPoint,
            EndPoint = model.EndPoint,
            Departure = model.Departure,
            Arrival = model.Arrival,
            DriverName = model.DriverName,
            TripType = model.TripType,
            TimeSlot = model.TimeSlot,
            BusStatus = model.BusStatus
        };

        var parameters = new DialogParameters<BusCrudDialog>
        {
            { x => x.BusModel, clonedModel }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<BusCrudDialog>($"Modify Fleet #{model.Id}", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is BusCrudDialog.BusUiModel updatedBus)
        {
            isLoading = true;
            try
            {
                var response = await Http.PutAsJsonAsync($"api/bus/{model.Id}/update", updatedBus);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Fleet #{model.Id} record updated successfully!", Severity.Success);
                    await LoadInventoryFromServer();
                }
                else
                {
                    MockSaveLocal(updatedBus, isNew: false);
                }
            }
            catch (Exception)
            {
                MockSaveLocal(updatedBus, isNew: false);
            }
            finally
            {
                isLoading = false;
            }
        }
    }

    private void MockSaveLocal(BusCrudDialog.BusUiModel model, bool isNew)
    {
        if (isNew)
        {
            long newId = allBuses.Any() ? allBuses.Max(b => b.Id) + 1 : 1;
            model.Id = newId;
            allBuses.Add(model);
            Snackbar.Add("Offline: Fleet registered locally.", Severity.Success);
        }
        else
        {
            var match = allBuses.FirstOrDefault(b => b.Id == model.Id);
            if (match != null)
            {
                match.BusName = model.BusName;
                match.BusNumber = model.BusNumber;
                match.BusClass = model.BusClass;
                match.TotalSeats = model.TotalSeats;
                match.Price = model.Price;
                match.StartPoint = model.StartPoint;
                match.EndPoint = model.EndPoint;
                match.Departure = model.Departure;
                match.TimeSlot = model.TimeSlot;
                match.BusStatus = model.BusStatus;
                Snackbar.Add($"Offline: Fleet #{model.Id} updated locally.", Severity.Success);
            }
        }
        FilterInventory();
    }

    private async Task OpenDeleteDialog(BusCrudDialog.BusUiModel model)
    {
        var parameters = new DialogParameters<DeleteConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete the bus plate '{model.BusNumber}' operating on the route {model.StartPoint} ➡️ {model.EndPoint}?" }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<DeleteConfirmDialog>("Delete Confirm", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            isLoading = true;
            try
            {
                var response = await Http.DeleteAsync($"api/bus/{model.Id}/delete");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Fleet record #{model.Id} deleted from server.", Severity.Success);
                    await LoadInventoryFromServer();
                }
                else
                {
                    MockDeleteLocal(model.Id);
                }
            }
            catch (Exception)
            {
                MockDeleteLocal(model.Id);
            }
            finally
            {
                isLoading = false;
            }
        }
    }

    private void MockDeleteLocal(long id)
    {
        var target = allBuses.FirstOrDefault(b => b.Id == id);
        if (target != null)
        {
            allBuses.Remove(target);
            Snackbar.Add("Offline: Fleet record removed locally.", Severity.Success);
            FilterInventory();
        }
    }
}
