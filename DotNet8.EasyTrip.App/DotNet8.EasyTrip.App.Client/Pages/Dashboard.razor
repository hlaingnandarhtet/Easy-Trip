@page "/dashboard"
@inherits ComponentBase
@rendermode InteractiveWebAssembly
@using System.Globalization

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="et-page dash-root">

    @if (_isLoading)
    {
        <div class="dash-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Style="font-weight:600; color:#64748B;">Loading unpaid transactions…</MudText>
        </div>
    }
    else
    {
        <!-- Hero -->
        <div class="dash-hero">
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:800; color:#fff; letter-spacing:-0.5px;">Dashboard</MudText>
                <MudText Style="color:rgba(255,255,255,0.85); font-size:0.9rem;">
                    Unpaid transactions overview — click a row to open bookings (pending filter)
                </MudText>
            </div>
            <div class="d-flex align-center gap-3 flex-wrap">
                <div class="dash-live-pill">
                    <span class="dash-pulse"></span>
                    @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt", CultureInfo.InvariantCulture)
                </div>
                <MudButton Variant="Variant.Filled" Class="dash-refresh-btn" OnClick="LoadDataAsync"
                           StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
            </div>
        </div>

        <!-- Stat cards -->
        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" sm="6" md="3">
                <div class="dash-stat dash-stat--primary" @onclick='() => SetFilter("All")'>
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Class="dash-stat-icon" />
                    <div class="dash-stat-label">Total Unpaid</div>
                    <div class="dash-stat-value">@_totalUnpaid</div>
                    <div class="dash-stat-sub">All booking types</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="dash-stat dash-stat--bus" @onclick='() => SetFilter("Bus")'>
                    <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" Class="dash-stat-icon" />
                    <div class="dash-stat-label">Bus</div>
                    <div class="dash-stat-value">@_busCount</div>
                    <div class="dash-stat-sub">Unpaid tickets</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="dash-stat dash-stat--hotel" @onclick='() => SetFilter("Hotel")'>
                    <MudIcon Icon="@Icons.Material.Filled.Hotel" Class="dash-stat-icon" />
                    <div class="dash-stat-label">Hotel</div>
                    <div class="dash-stat-value">@_hotelCount</div>
                    <div class="dash-stat-sub">Unpaid rooms</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="dash-stat dash-stat--pkg" @onclick='() => SetFilter("Package")'>
                    <MudIcon Icon="@Icons.Material.Filled.CardTravel" Class="dash-stat-icon" />
                    <div class="dash-stat-label">Package</div>
                    <div class="dash-stat-value">@_pkgCount</div>
                    <div class="dash-stat-sub">Unpaid packages</div>
                </div>
            </MudItem>
        </MudGrid>

        <!-- Charts -->
        @* <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" md="8">
                <MudPaper Class="dash-chart-card pa-4" Elevation="0">
                    <div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-2">
                        <div>
                            <MudText Typo="Typo.h6" Style="font-weight:700; color:#0F172A;">Unpaid Analytics</MudText>
                            <MudText Typo="Typo.caption" Style="color:#64748B;">Grouped bars by booking type</MudText>
                        </div>
                        <MudSelect T="string" @bind-Value="_barChartMode" Label="View" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Dense="true" Style="min-width:160px;" @bind-Value:after="UpdateCharts">
                            <MudSelectItem Value="@("count")">Count</MudSelectItem>
                            <MudSelectItem Value="@("amount")">Amount (mmk)</MudSelectItem>
                        </MudSelect>
                    </div>
                    <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_barSeries" ChartOptions="@_barChartOptions"
                              InputLabels="@_chartLabels" Width="100%" Height="280px" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="dash-chart-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Style="font-weight:700; color:#0F172A;">Distribution</MudText>
                    <MudText Typo="Typo.caption" Style="color:#64748B;" Class="mb-2">Share by type</MudText>
                    <MudChart T="double" ChartType="ChartType.Donut" ChartSeries="@_donutSeries" ChartOptions="@_donutChartOptions"
                              InputLabels="@_chartLabels" Width="100%" Height="280px" />
                    <div class="dash-revenue-total mt-3">
                        <span style="color:#64748B; font-size:0.8rem; font-weight:600;">TOTAL UNPAID</span>
                        <div style="font-size:1.35rem; font-weight:800; color:#0F172A;">@($"{_totalUnpaidAmount:N0}") mmk</div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid> *@

        <!-- Unpaid table -->
        <MudPaper Class="dash-table-card" Elevation="0">
            <div class="dash-table-head">
                <div>
                    <MudText Typo="Typo.h6" Style="font-weight:700; color:#0F172A;">Unpaid Transactions</MudText>
                    <MudText Typo="Typo.caption" Style="color:#64748B;">Click any row → Booking list (Pending filter)</MudText>
                </div>
                <div class="dash-chips">
                    <span class="dash-chip @(_filter == "All" ? "active" : "")" @onclick='() => SetFilter("All")'>All (@_totalUnpaid)</span>
                    <span class="dash-chip @(_filter == "Bus" ? "active" : "")" @onclick='() => SetFilter("Bus")'>Bus (@_busCount)</span>
                    <span class="dash-chip @(_filter == "Hotel" ? "active" : "")" @onclick='() => SetFilter("Hotel")'>Hotel (@_hotelCount)</span>
                    <span class="dash-chip @(_filter == "Package" ? "active" : "")" @onclick='() => SetFilter("Package")'>Package (@_pkgCount)</span>
                </div>
            </div>

            <MudTable T="BookingResponseModel" Items="@FilteredItems" Hover="true" Dense="false" Striped="false"
                      Elevation="0" Class="et-data-table dash-mud-table" OnRowClick="OnDashboardRowClick">
                <HeaderContent>
                    <MudTh>Transaction ID</MudTh>
                    <MudTh>Customer</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Service</MudTh>
                    <MudTh>Travel Date</MudTh>
                    <MudTh>Booked On</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><span class="dash-txn">TXN-@context.Id.ToString("D5")</span></MudTd>
                    <MudTd>
                        <div class="dash-name">@(context.UserName ?? "—")</div>
                        <div class="dash-email">@(context.UserEmail ?? "")</div>
                    </MudTd>
                    <MudTd><span class="et-badge et-badge--indigo">@context.BookingType</span></MudTd>
                    <MudTd Class="dash-service">@GetServiceShort(context)</MudTd>
                    <MudTd>@context.TravelDate.ToString("dd MMM yyyy")</MudTd>
                    <MudTd>@GetBookedOn(context)</MudTd>
                    <MudTd Class="dash-amount">@context.TotalAmount.ToString("N0") mmk</MudTd>
                    <MudTd><span class="et-badge et-badge--warning">Unpaid</span></MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="dash-empty py-8">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" Style="opacity:0.5;" />
                        <MudText Typo="Typo.h6" Style="font-weight:700;">No unpaid transactions</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }"
                                   InfoFormat="{first_item}-{last_item} of {all_items}"
                                   HorizontalAlignment="HorizontalAlignment.Right" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

