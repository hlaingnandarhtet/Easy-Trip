@page "/hotel-admin"
@inject HttpClient Http

<div class="container my-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-header-card p-4 rounded-3 shadow-sm border-0 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-1 header-title">Hotel Administration</h2>
                    <p class="text-muted mb-0">Create new hotels and configure multiple room types in a single form.</p>
                </div>
                <div class="header-badge bg-primary text-white px-3 py-2 rounded-2 fw-semibold">
                    Admin Portal
                </div>
            </div>
        </div>
    </div>

    <!-- Main Form -->
    <EditForm Model="@hotelRequest" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        
        <div class="row g-4">
            <!-- Left Panel: Hotel details -->
            <div class="col-lg-4">
                <div class="card p-4 border-0 shadow-sm rounded-3 form-side-card h-100">
                    <h4 class="fw-semibold mb-4 section-subtitle">Hotel Information</h4>
                    
                    <div class="mb-3">
                        <label for="hotelName" class="form-label fw-medium text-secondary">Hotel Name</label>
                        <InputText id="hotelName" class="form-control rounded-2 custom-input" placeholder="e.g. Grand Palace Resort" @bind-Value="hotelRequest.HotelName" required />
                    </div>

                    <div class="mb-4">
                        <label for="location" class="form-label fw-medium text-secondary">Location</label>
                        <InputText id="location" class="form-control rounded-2 custom-input" placeholder="e.g. Yangon, Myanmar" @bind-Value="hotelRequest.Location" required />
                    </div>

                    <div class="hotel-preview-card p-3 rounded-3 mt-auto">
                        <span class="preview-badge mb-2">Live Preview</span>
                        <h5 class="fw-bold text-dark mb-1">@(string.IsNullOrWhiteSpace(hotelRequest.HotelName) ? "New Hotel Name" : hotelRequest.HotelName)</h5>
                        <p class="text-muted mb-0"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@(string.IsNullOrWhiteSpace(hotelRequest.Location) ? "No Location Provided" : hotelRequest.Location)</p>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Room types many-to-many configurations -->
            <div class="col-lg-8">
                <div class="card p-4 border-0 shadow-sm rounded-3 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-semibold mb-0 section-subtitle">Rooms Configuration</h4>
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-2 d-flex align-items-center" @onclick="AddRoomRow">
                            <span class="fs-5 me-1">+</span> Add Room Type
                        </button>
                    </div>

                    @if (hotelRequest.HotelRooms == null || !hotelRequest.HotelRooms.Any())
                    {
                        <div class="text-center py-5 border border-dashed rounded-3 bg-light-subtle d-flex flex-column align-items-center">
                            <div class="empty-icon mb-3">🛏️</div>
                            <h6 class="text-secondary fw-semibold">No Room Configurations Added Yet</h6>
                            <p class="text-muted small mb-3">Add room configurations below to link room types, pricing, and available counts to this hotel.</p>
                            <button type="button" class="btn btn-primary btn-sm rounded-2 px-3" @onclick="AddRoomRow">Configure First Room</button>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle table-borderless room-table">
                                <thead class="table-light rounded-3">
                                    <tr>
                                        <th scope="col" style="width: 25%">Room Type</th>
                                        <th scope="col" style="width: 20%">Price per Night ($)</th>
                                        <th scope="col" style="width: 15%">Count</th>
                                        <th scope="col" style="width: 25%">Amenities</th>
                                        <th scope="col" style="width: 10%">Status</th>
                                        <th scope="col" style="width: 5%"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < hotelRequest.HotelRooms.Count; i++)
                                    {
                                        var index = i;
                                        var room = hotelRequest.HotelRooms[index];
                                        <tr>
                                            <!-- Room Type Selector -->
                                            <td>
                                                <select class="form-select rounded-2 custom-select" @bind="room.RoomTypeId" required>
                                                    <option value="" disabled selected>Select Room Type</option>
                                                    @foreach (var type in availableRoomTypes)
                                                    {
                                                        <option value="@type.Id">@type.TypeName</option>
                                                    }
                                                </select>
                                            </td>
                                            
                                            <!-- Price per Night -->
                                            <td>
                                                <InputNumber class="form-control rounded-2 custom-input text-end" @bind-Value="room.PricePerNight" min="1" placeholder="0.00" required />
                                            </td>
                                            
                                            <!-- Count of Available Rooms -->
                                            <td>
                                                <InputNumber class="form-control rounded-2 custom-input text-end" @bind-Value="room.AvailableRooms" min="1" placeholder="0" required />
                                            </td>
                                            
                                            <!-- Amenities Text input -->
                                            <td>
                                                <InputText class="form-control rounded-2 custom-input" @bind-Value="room.Amenities" placeholder="WiFi, Pool, Breakfast" />
                                            </td>

                                            <!-- HotelStatus (Room status) -->
                                            <td>
                                                <select class="form-select rounded-2 custom-select" @bind="room.HotelStatus">
                                                    <option value="@HotelStatus.Available">Available</option>
                                                    <option value="@HotelStatus.Full">Full</option>
                                                </select>
                                            </td>

                                            <!-- Remove Row Action -->
                                            <td>
                                                <button type="button" class="btn btn-outline-danger btn-sm border-0 rounded-circle p-2 d-flex justify-content-center align-items-center remove-btn" @onclick="() => RemoveRoomRow(index)">
                                                    ❌
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-3">
                        <button type="button" class="btn btn-light px-4 py-2 rounded-2" @onclick="ResetForm" disabled="@isSubmitting">Reset</button>
                        <button type="submit" class="btn btn-primary px-5 py-2 rounded-2 d-flex align-items-center gap-2 submit-btn" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span>Saving...</span>
                            }
                            else
                            {
                                <span>Save Hotel</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </EditForm>

    <!-- Response Message Alerts -->
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="alert alert-@alertClass alert-dismissible fade show rounded-3 p-3 shadow-sm border-0 d-flex align-items-center" role="alert">
                    <span class="fs-5 me-2">@(alertClass == "success" ? "✅" : "⚠️")</span>
                    <div>
                        <strong>@statusMessage</strong>
                    </div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close" @onclick="ClearStatus"></button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .admin-header-card {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-left: 5px solid #0052d4 !important;
    }
    .header-title {
        color: #1a2a6c;
    }
    .section-subtitle {
        color: #1e3c72;
        border-bottom: 2px solid #eef2f3;
        padding-bottom: 10px;
    }
    .form-side-card {
        background-color: #fbfbfb;
    }
    .custom-input, .custom-select {
        border: 1px solid #dcdcdc;
        padding: 10px 14px;
        transition: all 0.2s ease-in-out;
    }
    .custom-input:focus, .custom-select:focus {
        border-color: #0052d4;
        box-shadow: 0 0 0 0.25rem rgba(0, 82, 212, 0.15);
    }
    .hotel-preview-card {
        background-color: #ffffff;
        border: 1px dashed #c3cfe2;
        position: relative;
    }
    .preview-badge {
        font-size: 0.75rem;
        background-color: #ffe066;
        color: #8c6b00;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 4px;
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .room-table th {
        font-weight: 600;
        color: #4a5568;
        font-size: 0.875rem;
        padding: 12px;
    }
    .room-table td {
        padding: 10px 8px;
    }
    .remove-btn:hover {
        background-color: #fff5f5 !important;
    }
    .empty-icon {
        font-size: 3rem;
    }
    .submit-btn {
        background: linear-gradient(to right, #0052d4, #4364f7, #6fb1fc);
        border: none;
        color: white;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(67, 100, 247, 0.3);
        transition: all 0.3s ease;
    }
    .submit-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(67, 100, 247, 0.4);
    }
    .submit-btn:disabled {
        opacity: 0.7;
        transform: none;
    }
</style>

@code {
    private HotelRequestModel hotelRequest = new HotelRequestModel();
    private List<RoomTypeResponseModel> availableRoomTypes = new List<RoomTypeResponseModel>();
    
    private bool isSubmitting = false;
    private string statusMessage = "";
    private string alertClass = "info";

    protected override async Task OnInitializedAsync()
    {
        await LoadRoomTypes();
    }

    private async Task LoadRoomTypes()
    {
        try
        {
            // Call Backend Web API to load available master room types
            var response = await Http.GetFromJsonAsync<List<RoomTypeResponseModel>>("api/roomtypes");
            if (response != null)
            {
                availableRoomTypes = response;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading room types: {ex.Message}");
            // Fallback lookup options if the API connection isn't started yet
            availableRoomTypes = new List<RoomTypeResponseModel>
            {
                new RoomTypeResponseModel { Id = 1, TypeName = "Single" },
                new RoomTypeResponseModel { Id = 2, TypeName = "Double" },
                new RoomTypeResponseModel { Id = 3, TypeName = "Suite" },
                new RoomTypeResponseModel { Id = 4, TypeName = "Family Room" }
            };
        }
    }

    private void AddRoomRow()
    {
        if (hotelRequest.HotelRooms == null)
        {
            hotelRequest.HotelRooms = new List<HotelRoomRequestModel>();
        }

        hotelRequest.HotelRooms.Add(new HotelRoomRequestModel
        {
            PricePerNight = 100.00m,
            AvailableRooms = 5,
            HotelStatus = HotelStatus.Available,
            Amenities = "WiFi, TV"
        });
    }

    private void RemoveRoomRow(int index)
    {
        if (hotelRequest.HotelRooms != null && index >= 0 && index < hotelRequest.HotelRooms.Count)
        {
            hotelRequest.HotelRooms.RemoveAt(index);
        }
    }

    private void ResetForm()
    {
        hotelRequest = new HotelRequestModel();
        AddRoomRow();
    }

    private void ClearStatus()
    {
        statusMessage = "";
    }

    private async Task HandleSubmit()
    {
        if (isSubmitting) return;

        if (string.IsNullOrWhiteSpace(hotelRequest.HotelName) || string.IsNullOrWhiteSpace(hotelRequest.Location))
        {
            statusMessage = "Please fill in the Hotel Name and Location.";
            alertClass = "danger";
            return;
        }

        if (hotelRequest.HotelRooms == null || !hotelRequest.HotelRooms.Any())
        {
            statusMessage = "Please add at least one room configuration.";
            alertClass = "warning";
            return;
        }

        // Validate that each row has selected a room type
        if (hotelRequest.HotelRooms.Any(r => r.RoomTypeId == null || r.RoomTypeId == 0))
        {
            statusMessage = "Please select a valid Room Type for all added rows.";
            alertClass = "warning";
            return;
        }

        isSubmitting = true;
        statusMessage = "";
        
        try
        {
            // Post payload to backend API (creating hotel and linking rooms transactionally)
            var response = await Http.PostAsJsonAsync("api/hotel/create", hotelRequest);
            
            if (response.IsSuccessStatusCode)
            {
                var createdHotel = await response.Content.ReadFromJsonAsync<HotelResponseModel>();
                statusMessage = $"Success! Hotel '{createdHotel?.HotelName}' created successfully with {createdHotel?.HotelRooms?.Count} room configurations.";
                alertClass = "success";
                ResetForm();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                statusMessage = $"Failed to create hotel: {response.ReasonPhrase}. Details: {errorText}";
                alertClass = "danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred during submission: {ex.Message}";
            alertClass = "danger";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
