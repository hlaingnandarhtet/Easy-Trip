<MudDialog Class="et-dialog et-dialog-danger">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 800;">
            <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Class="mr-2" Color="Color.Error" />
            Delete Bus
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-0">
            This permanently removes the bus record. Bookings linked to this bus may be affected.
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Class="et-btn-ghost">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Confirm" Class="et-btn-primary">
            Delete
        </MudButton>
    </DialogActions>
</MudDialog>
