@page "/reports/booking-analytics"
@inherits ComponentBase
@rendermode InteractiveWebAssembly

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="et-page">
    <PageHeader Title="Booking Analytics Report"
                Subtitle="Booking volume, status breakdown, conversion rate, and payment status."
                Icon="@Icons.Material.Filled.Analytics">
        <Actions>
            <MudDatePicker Label="From" @bind-Date="_startDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable="true" DateFormat="dd-MM-yyyy" Style="min-width:140px;" />
            <MudDatePicker Label="To" @bind-Date="_endDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable="true" DateFormat="dd-MM-yyyy" Style="min-width:140px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="et-btn-primary"
                       OnClick="LoadReportAsync" StartIcon="@Icons.Material.Filled.Refresh"
                       Style="height:40px; text-transform:none; font-weight:600; border-radius:10px;">
                Apply
            </MudButton>
        </Actions>
    </PageHeader>

    @if (_isLoading)
    {
        <div class="rpt-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Style="font-weight:600; color:#64748B;">Loading booking analytics…</MudText>
        </div>
    }
    else if (_report == null)
    {
        <MudAlert Severity="Severity.Warning">Could not load report. Ensure the API is running.</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" sm="6" md="3">
                <div class="rpt-stat rpt-stat--blue">
                    <div class="rpt-stat-label">Total Bookings</div>
                    <div class="rpt-stat-value">@_report.TotalBookings</div>
                    <div class="rpt-stat-sub">All statuses in period</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="rpt-stat rpt-stat--green">
                    <div class="rpt-stat-label">Conversion Rate</div>
                    <div class="rpt-stat-value">@_report.ConversionRate.ToString("F1")%</div>
                    <div class="rpt-stat-sub">@_report.ConfirmedCount confirmed of @_report.TotalBookings</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="rpt-stat rpt-stat--amber">
                    <div class="rpt-stat-label">Avg Booking Value</div>
                    <div class="rpt-stat-value">@($"{_report.AverageBookingAmount:N0}") mmk</div>
                    <div class="rpt-stat-sub">Total @($"{_report.TotalBookingValue:N0}") mmk</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="rpt-stat rpt-stat--rose">
                    <div class="rpt-stat-label">Pending / Rejected</div>
                    <div class="rpt-stat-value">@_report.PendingCount / @_report.RejectedCount</div>
                    <div class="rpt-stat-sub">Requires attention</div>
                </div>
            </MudItem>
        </MudGrid>

        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" sm="4">
                <div class="rpt-stat">
                    <div class="rpt-stat-label">By Type — Bus</div>
                    <div class="rpt-stat-value">@_report.BusCount</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="rpt-stat">
                    <div class="rpt-stat-label">By Type — Hotel</div>
                    <div class="rpt-stat-value">@_report.HotelCount</div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="rpt-stat">
                    <div class="rpt-stat-label">By Type — Package</div>
                    <div class="rpt-stat-value">@_report.PackageCount</div>
                </div>
            </MudItem>
        </MudGrid>

        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" md="8">
                <MudPaper Class="rpt-chart-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Style="font-weight:700; color:#0F172A;">Booking Volume</MudText>
                    <MudText Typo="Typo.caption" Style="color:#64748B;" Class="mb-3">Daily bookings by status</MudText>
                    @if (_chartLabels.Length > 0)
                    {
                        <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_volumeSeries"
                                  ChartOptions="@_lineOptions" ChartLabels="@_chartLabels"
                                  Width="100%" Height="300px" />
                    }
                    else
                    {
                        <MudText Style="color:#94A3B8; padding:40px 0; text-align:center;">No bookings in this period.</MudText>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="rpt-chart-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Style="font-weight:700; color:#0F172A;">Status Breakdown</MudText>
                    <MudText Typo="Typo.caption" Style="color:#64748B;" Class="mb-3">Confirmed vs pending vs rejected</MudText>
                    @if (_report.TotalBookings > 0)
                    {
                        <MudChart T="double" ChartType="ChartType.Donut" ChartSeries="@_statusDonut"
                                  ChartOptions="@_donutOptions"
                                  ChartLabels="@(new[] { "Confirmed", "Pending", "Rejected" })"
                                  Width="100%" Height="280px" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="et-table-card" Elevation="0">
            <div class="et-table-toolbar">
                <MudText Typo="Typo.h6" Style="font-weight:700; color:#0F172A;">Payment Status Summary</MudText>
            </div>
            <MudSimpleTable Hover="true" Dense="true" Class="et-data-table">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Count</th>
                        <th>Share</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="et-badge et-badge--success">Paid</span></td>
                        <td>@_report.PaidCount</td>
                        <td>@Pct(_report.PaidCount, _report.TotalBookings)</td>
                    </tr>
                    <tr>
                        <td><span class="et-badge et-badge--warning">Unpaid</span></td>
                        <td>@_report.UnpaidCount</td>
                        <td>@Pct(_report.UnpaidCount, _report.TotalBookings)</td>
                    </tr>
                    <tr>
                        <td><span class="et-badge et-badge--indigo">Under Review</span></td>
                        <td>@_report.UnderReviewCount</td>
                        <td>@Pct(_report.UnderReviewCount, _report.TotalBookings)</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
</MudContainer>

@code {
    private static string Pct(int part, int total) =>
        total == 0 ? "0%" : $"{Math.Round(100.0 * part / total, 1)}%";
}
